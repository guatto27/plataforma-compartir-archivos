# Copia este archivo como .env y ajusta los valores.
# NUNCA subas .env al repositorio.

# Puerto del servidor
PORT=3000

# Entorno: development | production
NODE_ENV=development

# Secreto para firmar las cookies de sesión.
# Genera uno fuerte con:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# Tamaño máximo por archivo (MB). Considera que audio y video pesan mucho.
MAX_FILE_MB=1024

# Extensiones permitidas (separadas por coma, en minúsculas, sin punto)
ALLOWED_EXT=pdf,doc,docx,odt,rtf,txt,csv,md,xls,xlsx,ods,ppt,pptx,odp,key,png,jpg,jpeg,gif,webp,bmp,svg,heic,tif,tiff,mp3,wav,m4a,aac,ogg,flac,mp4,mov,avi,mkv,webm,wmv,flv,zip,rar,7z

# Carpeta de datos PERSISTENTES (recomendado en VPS). Apúntala a una ruta fuera
# del directorio del proyecto para que la BD y los archivos NO se borren al
# actualizar el código. Dentro se crean: <DATA_DIR>/data/portal.db y
# <DATA_DIR>/storage/uploads/. Ejemplo en VPS Linux:
# DATA_DIR=/var/businesscool-data

# Administrador inicial (opcional). Si se definen y ese usuario no existe,
# se crea automáticamente un admin al arrancar. Útil en despliegues con BD vacía.
# Usa minúsculas para el usuario y una contraseña fuerte (mín. 8 caracteres).
ADMIN_USERNAME=marco
ADMIN_PASSWORD=cambia-esta-contraseña-fuerte
