<%- include('../partials/shell-header') %>

<div class="page-head">
  <div class="head-row">
    <div>
      <h1>Información requerida</h1>
      <p class="muted"><%= companyName || brand.name %><% if (projectName) { %> · <%= projectName %><% } %></p>
    </div>
  </div>
</div>

<% if (!items || !items.length) { %>
  <div class="empty-state">
    <p>Por ahora no hay información pendiente por entregar para este proyecto. Cuando el equipo de BusinessCool AI la solicite, aparecerá aquí y te llegará una notificación.</p>
  </div>
<% } else { %>
  <%
    var entregados = items.filter(function(i){ return (filesByItem[i.id]||[]).length || i.validado; }).length;
    var pct = Math.round((entregados / items.length) * 100);
  %>
  <section class="card" style="margin-bottom:18px">
    <p style="margin:0 0 8px">El equipo de <strong>BusinessCool AI</strong> necesita la siguiente información para avanzar con tu proyecto. Usa los iconos de <strong>Acciones</strong> para subir archivos, ver comentarios o eliminar entregas.</p>
    <div class="table-progress" style="max-width:420px"><div style="width:<%= pct %>%"></div></div>
    <p class="meta" style="margin:6px 0 0"><%= entregados %> de <%= items.length %> puntos entregados (<%= pct %>%)</p>
  </section>

  <section class="card">
    <div class="table-wrap">
      <table class="table chk-table">
        <thead>
          <tr>
            <th style="width:34px">#</th>
            <th>Información solicitada</th>
            <th>Responsable</th>
            <th>Archivos entregados</th>
            <th class="nowrap">Última entrega</th>
            <th class="ta-center">Estado</th>
            <th class="ta-actions">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% items.forEach(function (it, idx) { %>
            <% var fls = filesByItem[it.id] || []; %>
            <tr>
              <td class="meta"><%= idx + 1 %></td>
              <td>
                <strong><%= it.titulo %></strong>
                <% if (it.descripcion) { %><div class="meta"><%= it.descripcion %></div><% } %>
              </td>
              <td>
                <% if (it.responsable) { %><%= it.responsable %><% } else { %><span class="meta">—</span><% } %>
              </td>
              <td>
                <% if (!fls.length) { %><span class="meta">—</span><% } else { %>
                  <% fls.forEach(function (f) { %>
                    <a class="chk-file-line" href="/app/informacion/archivo/<%= f.id %>/descargar" title="<%= f.file_name %> · <%= fmtDate(f.created_at) %>"><%= f.file_name %></a>
                  <% }) %>
                <% } %>
              </td>
              <td class="nowrap meta">
                <% if (fls.length) { %><%= fmtDate(fls[fls.length - 1].created_at) %><% } else { %>—<% } %>
              </td>
              <td class="ta-center">
                <% if (it.validado) { %><span class="st-chip st-fin">Validado ✓</span>
                <% } else if (fls.length) { %><span class="st-chip st-vig">Entregado</span>
                <% } else { %><span class="st-chip st-pau">Pendiente</span><% } %>
              </td>
              <td class="ta-actions">
                <!-- Subir archivos -->
                <% if (!it.validado) { %>
                  <form method="post" action="/app/informacion/<%= it.id %>/subir" enctype="multipart/form-data" class="inline">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <input type="file" name="archivos" multiple id="chk-input-<%= it.id %>" data-submit-on-change hidden />
                    <button class="iconbtn" type="button" data-upload-trigger="chk-input-<%= it.id %>" title="Subir archivos" aria-label="Subir archivos">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                    </button>
                  </form>
                <% } else { %>
                  <button class="iconbtn" type="button" disabled title="Punto validado: ya no se cargan archivos" aria-label="Subir archivos">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                  </button>
                <% } %>

                <!-- Comentario del proveedor -->
                <% if (it.comentario) { %>
                  <button class="iconbtn has-coment" type="button" data-dialog="chk-com-<%= it.id %>" title="Ver comentario de BusinessCool" aria-label="Ver comentario">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                  </button>
                <% } else { %>
                  <button class="iconbtn" type="button" disabled title="Sin comentarios de BusinessCool" aria-label="Sin comentarios">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                  </button>
                <% } %>

                <!-- Nota / duda del cliente hacia BusinessCool -->
                <button class="iconbtn <%= it.nota_cliente ? 'has-nota' : '' %>" type="button" data-dialog="chk-nota-<%= it.id %>" title="<%= it.nota_cliente ? 'Ver / editar tu nota' : 'Escribir una nota o duda a BusinessCool' %>" aria-label="Nota para BusinessCool">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z"/></svg>
                </button>

                <!-- Eliminar archivos -->
                <% if (fls.length && !it.validado) { %>
                  <button class="iconbtn danger" type="button" data-dialog="chk-files-<%= it.id %>" title="Eliminar archivos entregados" aria-label="Eliminar archivos">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                  </button>
                <% } else { %>
                  <button class="iconbtn" type="button" disabled title="<%= it.validado ? 'Punto validado: los archivos ya no se eliminan' : 'Sin archivos para eliminar' %>" aria-label="Eliminar archivos">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                  </button>
                <% } %>

                <!-- Aceptado por BusinessCool -->
                <button class="iconbtn <%= it.validado ? 'is-locked' : '' %>" type="button" disabled title="<%= it.validado ? 'Aceptado por BusinessCool' : 'Aún no aceptado por BusinessCool' %>" aria-label="Aceptado por BusinessCool">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M8 12.4l2.6 2.6 5-5.6"/></svg>
                </button>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>

  <!-- Modales: comentario del proveedor -->
  <% items.forEach(function (it) { if (!it.comentario) return; %>
    <dialog id="chk-com-<%= it.id %>" class="modal" style="width:min(520px,94vw)">
      <div class="head-row" style="margin-bottom:10px">
        <h2 style="margin:0;font-size:17px">Comentario de BusinessCool</h2>
        <button class="btn btn-ghost btn-sm" type="button" data-close>✕ Cerrar</button>
      </div>
      <p class="meta" style="margin:0 0 10px"><%= it.titulo %></p>
      <div class="chk-coment" style="max-width:none;display:block"><%= it.comentario %></div>
    </dialog>
  <% }) %>

  <!-- Modales: nota / duda del cliente -->
  <% items.forEach(function (it) { %>
    <dialog id="chk-nota-<%= it.id %>" class="modal" style="width:min(520px,94vw)" data-strict>
      <div class="head-row" style="margin-bottom:10px">
        <h2 style="margin:0;font-size:17px">Nota para BusinessCool</h2>
        <button class="btn btn-ghost btn-sm" type="button" data-close>✕ Cerrar</button>
      </div>
      <p class="meta" style="margin:0 0 10px"><%= it.titulo %></p>
      <form method="post" action="/app/informacion/<%= it.id %>/nota">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <label>Nota o duda (el equipo de BusinessCool recibirá una notificación)
          <textarea name="nota" rows="4" maxlength="600" style="width:100%;resize:vertical" placeholder="ej. Esta información no existe como tal; ¿les sirve el reporte del ERP?"><%= it.nota_cliente || '' %></textarea>
        </label>
        <label>Responsable de este punto en tu equipo (opcional)
          <input type="text" name="responsable" value="<%= it.responsable || '' %>" maxlength="120" placeholder="ej. Melissa Aguirre / área de TI" />
        </label>
        <div class="modal-actions">
          <button class="btn btn-primary" type="submit">Guardar y notificar</button>
          <button class="btn btn-ghost" type="button" data-close>Cancelar</button>
        </div>
      </form>
    </dialog>
  <% }) %>

  <!-- Modales: eliminar archivos -->
  <% items.forEach(function (it) { var fls = filesByItem[it.id] || []; if (!fls.length || it.validado) return; %>
    <dialog id="chk-files-<%= it.id %>" class="modal" style="width:min(560px,94vw)">
      <div class="head-row" style="margin-bottom:10px">
        <h2 style="margin:0;font-size:17px">Archivos entregados</h2>
        <button class="btn btn-ghost btn-sm" type="button" data-close>✕ Cerrar</button>
      </div>
      <p class="meta" style="margin:0 0 10px"><%= it.titulo %></p>
      <% fls.forEach(function (f) { %>
        <div style="display:flex;align-items:center;gap:10px;margin:6px 0;padding:8px 10px;border:1px solid var(--bc-border);border-radius:8px">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px;color:var(--bc-gold);flex-shrink:0"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          <a href="/app/informacion/archivo/<%= f.id %>/descargar" style="flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="<%= f.file_name %>"><%= f.file_name %></a>
          <span class="meta" style="white-space:nowrap"><%= fmtDate(f.created_at) %></span>
          <form method="post" action="/app/informacion/archivo/<%= f.id %>/eliminar" class="inline" data-confirm="¿Eliminar “<%= f.file_name %>”?">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button class="iconbtn danger" type="submit" title="Eliminar" aria-label="Eliminar" style="width:28px;height:28px">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:12px;height:12px"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
            </button>
          </form>
        </div>
      <% }) %>
    </dialog>
  <% }) %>
<% } %>

<%- include('../partials/shell-footer') %>
