<%- include('../partials/shell-header') %>

<div class="page-head">
  <div class="head-row">
    <div>
      <h1>Información requerida</h1>
      <p class="muted"><%= companyName || brand.name %><% if (projectName) { %> · <%= projectName %><% } %></p>
    </div>
  </div>
</div>

<% if (!items || !items.length) { %>
  <div class="empty-state">
    <p>Por ahora no hay información pendiente por entregar para este proyecto. Cuando el equipo de BusinessCool AI la solicite, aparecerá aquí y te llegará una notificación.</p>
  </div>
<% } else { %>
  <%
    var entregados = items.filter(function(i){ return (filesByItem[i.id]||[]).length || i.validado; }).length;
    var pct = Math.round((entregados / items.length) * 100);
  %>
  <section class="card" style="margin-bottom:18px">
    <p style="margin:0 0 8px">El equipo de <strong>BusinessCool AI</strong> necesita la siguiente información para avanzar con tu proyecto. Sube los archivos en cada punto (puedes seleccionar varios a la vez).</p>
    <div class="table-progress" style="max-width:420px"><div style="width:<%= pct %>%"></div></div>
    <p class="meta" style="margin:6px 0 0"><%= entregados %> de <%= items.length %> puntos entregados (<%= pct %>%)</p>
  </section>

  <section class="card">
    <div class="table-wrap">
      <table class="table chk-table">
        <thead>
          <tr>
            <th style="width:34px">#</th>
            <th>Información solicitada</th>
            <th class="ta-center">Estado</th>
            <th>Archivos entregados</th>
            <th>Comentario de BusinessCool</th>
            <th class="ta-actions" style="min-width:230px">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% items.forEach(function (it, idx) { %>
            <% var fls = filesByItem[it.id] || []; %>
            <tr>
              <td class="meta"><%= idx + 1 %></td>
              <td>
                <strong><%= it.titulo %></strong>
                <% if (it.descripcion) { %><div class="meta"><%= it.descripcion %></div><% } %>
              </td>
              <td class="ta-center">
                <% if (it.validado) { %><span class="st-chip st-fin">Validado ✓</span>
                <% } else if (fls.length) { %><span class="st-chip st-vig">Entregado</span>
                <% } else { %><span class="st-chip st-pau">Pendiente</span><% } %>
              </td>
              <td>
                <% if (!fls.length) { %><span class="meta">—</span><% } else { %>
                  <% fls.forEach(function (f) { %>
                    <div style="display:flex;align-items:center;gap:8px;margin:3px 0">
                      <a href="/app/informacion/archivo/<%= f.id %>/descargar" title="Descargar"><%= f.file_name %></a>
                      <span class="meta"><%= fmtDate(f.created_at) %></span>
                      <% if (!it.validado) { %>
                        <form method="post" action="/app/informacion/archivo/<%= f.id %>/eliminar" class="inline" data-confirm="¿Eliminar “<%= f.file_name %>”?">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                          <button class="iconbtn danger" type="submit" title="Eliminar" aria-label="Eliminar" style="width:24px;height:24px">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:11px;height:11px"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                          </button>
                        </form>
                      <% } %>
                    </div>
                  <% }) %>
                <% } %>
              </td>
              <td>
                <% if (it.comentario) { %>
                  <span class="chk-coment"><%= it.comentario %></span>
                <% } else { %>
                  <span class="meta">—</span>
                <% } %>
              </td>
              <td class="ta-actions">
                <% if (!it.validado) { %>
                  <form method="post" action="/app/informacion/<%= it.id %>/subir" enctype="multipart/form-data" class="chk-upload">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <input type="file" name="archivos" multiple required />
                    <button class="btn btn-primary btn-sm" type="submit">Subir</button>
                  </form>
                <% } else { %>
                  <span class="meta">Validado — sin pendientes</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>
<% } %>

<%- include('../partials/shell-footer') %>
