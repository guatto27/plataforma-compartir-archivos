<%- include('../partials/shell-header') %>

<div class="page-head">
  <p class="muted" style="margin:0 0 2px"><%= companyName || brand.name %> · Proyecto de diagnóstico con IA</p>
  <h1>Pipeline del proyecto</h1>
  <p class="muted">El proyecto avanza por fases, cada una con un entregable formal obligatorio. La <strong>Fase 1 — Diagnóstico As-Is</strong> levanta los requerimientos, mapea los procesos actuales e integra los hallazgos: es la materia prima sobre la que se construye el rediseño To-Be con IA.</p>
</div>

<div class="phase-head">
  <span class="ph-state <%= phase.state %>"><%= phase.label %></span>
  <h2>Fase 1 · <%= phase.name %></h2>
  <span class="muted">· <%= phase.sub %> · Entregable: <strong><%= phase.entregable %></strong></span>
</div>

<div class="carousel-row">
  <button class="carousel-nav" type="button" data-carousel="prev" aria-label="Anterior">‹</button>
  <div class="steps" id="steps-track">
    <% phase.items.forEach(function (it) { %>
      <div class="step-card <%= it.state %>">
        <div class="step-top">
          <span class="step-num"><%= it.n %></span>
          <span class="step-state <%= it.state %>"><%= it.stateLabel %></span>
        </div>
        <h3><%= it.t %></h3>
        <div class="step-paso"><%= it.paso %></div>
        <p class="step-desc"><%= it.desc %></p>
      </div>
    <% }) %>

    <% if (typeof nextPhase !== 'undefined' && nextPhase) { %>
      <div class="step-card next-phase-card">
        <div class="step-top">
          <span class="step-num next-phase-num">Fase 2</span>
          <span class="step-state pending"><%= nextPhase.label %></span>
        </div>
        <h3><%= nextPhase.name %></h3>
        <p class="step-desc muted"><%= nextPhase.sub %></p>
        <ul class="next-phase-items">
          <% nextPhase.items.forEach(function(it){ %>
            <li><%= it.t %></li>
          <% }) %>
        </ul>
        <div class="next-phase-entregable">
          <span class="lbl-small">Entregable</span>
          <span><%= nextPhase.entregable %></span>
        </div>
      </div>
    <% } %>
  </div>
  <button class="carousel-nav" type="button" data-carousel="next" aria-label="Siguiente">›</button>
</div>

<%- include('../partials/shell-footer') %>
