<%- include('../partials/shell-header') %>

<div class="page-head">
  <p class="muted" style="margin:0 0 2px"><%= companyName || brand.name %> · Proyecto de diagnóstico con IA</p>
  <h1>Pipeline del proyecto</h1>
  <p class="muted">El proyecto avanza por fases, cada una con un entregable formal obligatorio. La <strong>Fase 1 — Diagnóstico As-Is</strong> levanta los requerimientos, mapea los procesos actuales e integra los hallazgos: es la materia prima sobre la que se construye el rediseño To-Be con IA. Desliza para ver todas las fases.</p>
</div>

<div class="carousel">
  <button class="carousel-nav prev" type="button" data-carousel="prev" aria-label="Anterior">‹</button>
  <div class="pipeline" id="pipeline-track">
    <% phases.forEach(function (p, idx) { %>
      <div class="phase <%= p.state %>">
        <div class="phase-topline">
          <span class="phase-num">Fase <%= idx + 1 %></span>
          <span class="ph-state"><%= p.label %></span>
        </div>
        <h3><%= p.name %></h3>
        <div class="ph-sub"><%= p.sub %></div>
        <ul>
          <% p.items.forEach(function (it) {
               var cls = it.state ? (it.state === 'current' ? 'cur' : (it.state === 'done' ? 'ok' : '')) : (it.s || '');
          %>
            <li class="<%= cls %>">
              <span class="it-title"><%= it.t %></span>
              <% if (it.paso) { %><span class="it-paso"><%= it.paso %></span><% } %>
              <% if (it.desc) { %><span class="it-desc"><%= it.desc %></span><% } %>
            </li>
          <% }) %>
        </ul>
        <div class="entregable-box">
          <div class="lbl">Entregable formal</div>
          <div class="val"><%= p.entregable %></div>
        </div>
      </div>
    <% }) %>
  </div>
  <button class="carousel-nav next" type="button" data-carousel="next" aria-label="Siguiente">›</button>
</div>

<%- include('../partials/shell-footer') %>
