<%- include('../partials/shell-header') %>

<div class="page-head">
  <div class="head-row">
    <div>
      <h1>Minutas semanales</h1>
      <p class="muted"><%= companyName || brand.name %></p>
    </div>
  </div>
</div>

<% if (minutas && minutas.length > 0) { %>
  <% minutas.forEach(function (m) { %>
    <section class="card minuta-summary" style="margin-bottom:20px">
      <div class="head-row">
        <div>
          <h2 style="margin:0"><%= m.titulo %></h2>
          <span class="meta"><%= m.fecha %></span>
          <% if (m.firmada) { %><span class="st aprob" style="margin-left:8px">Firmada electrónicamente</span><% } %>
        </div>
      </div>
      <% if (m.archivo_path) { %>
        <div style="margin-top:14px">
          <a href="/app/minutas/<%= m.id %>/descargar" class="btn btn-ghost" style="display:inline-flex;align-items:center;gap:6px">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Descargar minuta (<%= m.archivo_nombre || 'archivo' %>)
          </a>
        </div>
      <% } %>
      <% if (m.contenido) { %>
        <div class="minuta-preview" style="margin-top:14px"><%= m.contenido %></div>
      <% } %>
    </section>
  <% }) %>
<% } else { %>
  <div class="empty-state">
    <p>Aún no hay minutas publicadas. El equipo de BusinessCool AI las subirá después de cada sesión.</p>
  </div>
<% } %>

<%- include('../partials/shell-footer') %>
