<%- include('../partials/header') %>

<div class="page-head">
  <h1>Mi espacio</h1>
  <p class="muted">Hola, <%= currentUser.displayName %>. Aquí compartes archivos con el equipo de <%= brand.name %> y registras tu entrevista de diagnóstico.</p>
</div>

<section class="status-panel">
  <div class="status-top">
    <strong>Estado de tu diagnóstico</strong>
    <span class="status-pct"><%= status.percent %>% completado</span>
  </div>
  <div class="status-bar"><span style="width: <%= status.percent %>%"></span></div>
  <div class="status-steps">
    <div class="status-step <%= status.interview ? 'done' : 'todo' %>">
      <span class="badge"><%= status.interview ? '✓' : '1' %></span>
      <div>
        <strong>Entrevista</strong>
        <small><%= status.interview ? 'Enlace enviado' : 'Pendiente de enviar' %></small>
      </div>
    </div>
    <div class="status-step info">
      <span class="badge"><%= status.docsReceived %></span>
      <div>
        <strong>Documentos recibidos</strong>
        <small><%= status.docsReceived ? 'Disponibles para descargar' : 'Nada por ahora' %></small>
      </div>
    </div>
    <div class="status-step <%= status.uploaded ? 'done' : 'todo' %>">
      <span class="badge"><%= status.uploaded ? '✓' : '2' %></span>
      <div>
        <strong>Tus archivos</strong>
        <small><%= status.uploaded ? status.uploaded + ' enviado(s)' : 'Pendiente de subir' %></small>
      </div>
    </div>
  </div>
</section>

<div class="grid">

  <!-- Entrevista de diagnóstico -->
  <section class="card">
    <h2>1. Entrevista de diagnóstico</h2>
    <p class="muted">Realiza la entrevista en el asistente de Gemini. Al terminar, pega aquí el enlace de la conversación.</p>
    <form method="post" action="/app/interview">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label>Enlace de la entrevista
        <input type="url" name="url" placeholder="https://..." required maxlength="2000" />
      </label>
      <label>Notas (opcional)
        <input type="text" name="notes" maxlength="500" />
      </label>
      <button class="btn btn-primary" type="submit">Enviar enlace</button>
    </form>

    <% if (links.length) { %>
      <ul class="list">
        <% links.forEach((l) => { %>
          <li>
            <a href="<%= l.url %>" target="_blank" rel="noopener noreferrer">Entrevista enviada</a>
            <span class="meta"><%= l.created_at %> UTC</span>
            <% if (l.notes) { %><div class="meta"><%= l.notes %></div><% } %>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </section>

  <!-- Documentos del consultor -->
  <section class="card">
    <h2>2. Documentos compartidos contigo</h2>
    <p class="muted">Plantillas y formatos que el equipo de <%= brand.name %> puso a tu disposición.</p>
    <% if (sharedByAdmin.length === 0) { %>
      <p class="empty">Aún no hay documentos compartidos.</p>
    <% } else { %>
      <ul class="list">
        <% sharedByAdmin.forEach((f) => { %>
          <li>
            <a href="/app/file/<%= f.id %>/download"><%= f.original_name %></a>
            <span class="meta"><%= Math.max(1, Math.round(f.size/1024)) %> KB · <%= f.created_at %> UTC</span>
            <% if (f.description) { %><div class="meta"><%= f.description %></div><% } %>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </section>

  <!-- Subir archivos -->
  <section class="card">
    <h2>3. Enviar archivos al consultor</h2>
    <p class="muted">Sube los archivos que te soliciten: documentos (Word, Excel, PowerPoint, PDF), imágenes, audio y video. Máx. <%= maxFileMb %> MB por archivo (hasta 10 a la vez).</p>
    <form method="post" action="/app/upload" enctype="multipart/form-data">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label>Archivos
        <input type="file" name="files" multiple required />
      </label>
      <label>Descripción (opcional)
        <input type="text" name="description" maxlength="500" />
      </label>
      <button class="btn btn-primary" type="submit">Enviar</button>
    </form>

    <% if (myUploads.length) { %>
      <h3>Enviados</h3>
      <ul class="list">
        <% myUploads.forEach((f) => { %>
          <li>
            <a href="/app/file/<%= f.id %>/download"><%= f.original_name %></a>
            <span class="meta"><%= Math.max(1, Math.round(f.size/1024)) %> KB · <%= f.created_at %> UTC</span>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </section>

</div>

<%- include('../partials/footer') %>
