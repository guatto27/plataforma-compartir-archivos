<%- include('../partials/shell-header') %>

<div class="page-head">
  <div class="head-row">
    <div>
      <h1>Entrevistas y Encuestas IMA</h1>
      <p class="muted">Realiza cada entrevista en el asistente de Gemini, guarda el link que te da al terminar y asocia tus archivos.</p>
    </div>
    <% if (typeof isResponsable !== 'undefined' && isResponsable) { %>
      <a class="btn btn-ghost" href="/app/archivos">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-3px;margin-right:6px"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
        Ver archivos del proyecto
      </a>
    <% } else { %>
      <a class="btn btn-ghost" href="/app/entregables">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-3px;margin-right:6px"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
        Ver archivos
      </a>
    <% } %>
  </div>
</div>

<%- include('../partials/interviewtable') %>

<%- include('../partials/shell-footer') %>
