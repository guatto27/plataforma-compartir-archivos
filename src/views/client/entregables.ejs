<%- include('../partials/shell-header') %>

<div class="page-head">
  <div class="head-row">
    <div>
      <h1>Entregables</h1>
      <p class="muted">Revisa los entregables formales de cada fase y comparte los archivos de tu proyecto.</p>
    </div>
    <button class="btn btn-primary" type="button" data-dialog="dlg-add-file">+ Agregar archivo</button>
  </div>
</div>

<% if (interview) { %>
  <div class="flash flash-success">Mostrando archivos de la entrevista: <strong><%= interview.nombre %></strong> — <a href="/app/entregables">ver todos</a></div>
<% } %>

<section class="card">
  <h2>Aprobación de entregables</h2>
  <p class="muted">Estado de cada entregable por fase. (Vista de ejemplo; la aprobación en línea se habilitará pronto.)</p>
  <% deliverables.forEach(function (d) { %>
    <div class="deliv">
      <div class="fase"><%= d.fase %></div>
      <div class="deliv-body">
        <strong><%= d.name %></strong>
        <span class="meta"><%= d.phase %></span>
      </div>
      <div class="deliv-actions">
        <% if (d.status === 'aprob') { %>
          <span class="st aprob">Aprobado</span>
        <% } else if (d.status === 'rev') { %>
          <span class="st rev">En revisión</span>
        <% } else { %>
          <span class="st pend">Pendiente</span>
        <% } %>
      </div>
    </div>
  <% }) %>
</section>

<section class="card" style="margin-top:20px">
  <h2>Archivos del proyecto</h2>
  <p class="muted">Plantillas, formatos, bases de datos, imágenes, audio y video. Máx. <%= maxFileMb %> MB por archivo.</p>
  <%- include('../partials/filetable') %>
</section>

<dialog id="dlg-add-file" class="modal" data-strict <%= interview ? 'data-autoopen' : '' %>>
  <h2>Agregar archivo<% if (interview) { %> · <%= interview.nombre %><% } %></h2>
  <form method="post" action="/app/upload" enctype="multipart/form-data">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <% if (interview) { %>
      <input type="hidden" name="interview_id" value="<%= interview.id %>" />
      <p class="meta">Se asociará a la entrevista de <strong><%= interview.nombre %></strong>.</p>
    <% } else { %>
      <label>Entrevista relacionada (opcional)
        <select name="interview_id">
          <option value="">— Ninguna —</option>
          <% interviews.forEach(function (iv) { %>
            <option value="<%= iv.id %>"><%= iv.nombre %><% if (iv.cargo) { %> · <%= iv.cargo %><% } %></option>
          <% }) %>
        </select>
      </label>
    <% } %>
    <label>Archivos
      <input type="file" name="files" multiple required />
    </label>
    <label>Descripción (opcional)
      <input type="text" name="description" maxlength="500" />
    </label>
    <div class="modal-actions">
      <button class="btn btn-primary" type="submit">Subir</button>
      <button class="btn btn-ghost" type="button" data-close>Cancelar</button>
    </div>
  </form>
</dialog>

<%- include('../partials/shell-footer') %>
