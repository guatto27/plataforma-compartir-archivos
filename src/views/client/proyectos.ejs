<%- include('../partials/shell-header') %>

<div class="page-head">
  <p class="muted" style="margin:0 0 2px"><%= companyName || brand.name %></p>
  <h1>Proyectos</h1>
  <p class="muted">Listado de proyectos de tu empresa con su estatus y avance. Aquí ves todo el panorama de lo que trabajamos contigo.</p>
</div>

<section class="card">
  <% if (!rows || !rows.length) { %>
    <p class="empty">Aún no hay proyectos registrados para tu empresa. En cuanto se registren, aparecerán aquí con su avance.</p>
  <% } else { %>
    <div class="table-wrap">
      <table class="table">
        <thead>
          <tr>
            <th>Proyecto</th>
            <th class="ta-center">Estatus</th>
            <th class="ta-center">Entregables</th>
            <th class="ta-center">Minutas</th>
            <th class="ta-center">Entrevistas</th>
            <th class="th-progress">Avance</th>
            <th class="ta-actions">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% rows.forEach(function (r) { %>
            <% var stCls = r.status === 'Finalizado' ? 'st-fin' : (r.status === 'En pausa' ? 'st-pau' : 'st-vig'); %>
            <tr<%= activeProject && r.id === activeProject.id ? ' class="row-active"' : '' %>>
              <td class="fname">
                <strong><%= r.name %></strong>
                <% if (activeProject && r.id === activeProject.id) { %><span class="meta" style="display:block">Proyecto en vista</span><% } %>
              </td>
              <td class="ta-center"><span class="st-chip <%= stCls %>"><%= r.status %></span></td>
              <td class="ta-center"><%= r.files %></td>
              <td class="ta-center"><%= r.minutas %></td>
              <td class="ta-center"><%= r.interviews %></td>
              <td>
                <div class="table-progress">
                  <div class="progress-bar"><span style="width:<%= r.pct %>%"></span></div>
                  <span class="table-progress-pct"><%= r.pct %>%</span>
                </div>
              </td>
              <td class="ta-actions">
                <a class="btn btn-ghost btn-sm" href="/app/seleccionar?id=<%= r.id %>">Ver</a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<%- include('../partials/shell-footer') %>
