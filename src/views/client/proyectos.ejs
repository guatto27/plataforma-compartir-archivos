<%- include('../partials/shell-header') %>

<%
  var stCls = projectStatus === 'Finalizado' ? 'st-fin' : (projectStatus === 'En pausa' ? 'st-pau' : 'st-vig');
  // Avance estimado a partir de las fases (current = en curso)
  var total = phases.length;
  var doneCount = 0;
  phases.forEach(function (p) { if (p.state === 'done') doneCount++; });
  var hasCurrent = phases.some(function (p) { return p.state === 'current'; });
  var pct = total ? Math.round(((doneCount + (hasCurrent ? 0.5 : 0)) / total) * 100) : 0;
%>

<div class="page-head">
  <p class="muted" style="margin:0 0 2px"><%= companyName || brand.name %></p>
  <h1>Proyectos</h1>
  <p class="muted">Listado de proyectos de tu empresa con su estatus y avance. Aquí ves todo el panorama de lo que trabajamos contigo.</p>
</div>

<section class="card">
  <% if (!projectName) { %>
    <p class="empty">Aún no hay un proyecto asignado a tu empresa. En cuanto se registre, aparecerá aquí con su avance.</p>
  <% } else { %>
    <div class="table-wrap">
      <table class="table">
        <thead>
          <tr>
            <th>Proyecto</th>
            <th class="ta-center">Estatus</th>
            <th class="ta-center">Entregables</th>
            <th class="ta-center">Minutas</th>
            <th class="ta-center">Entrevistas</th>
            <th class="th-progress">Avance</th>
            <th class="ta-actions">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="fname">
              <strong><%= projectName %></strong>
              <span class="meta" style="display:block"><%= companyName %></span>
            </td>
            <td class="ta-center"><span class="st-chip <%= stCls %>"><%= projectStatus %></span></td>
            <td class="ta-center"><%= filesCount %></td>
            <td class="ta-center"><%= minutasCount %></td>
            <td class="ta-center"><%= interviewsCount %></td>
            <td>
              <div class="table-progress">
                <div class="progress-bar"><span style="width:<%= pct %>%"></span></div>
                <span class="table-progress-pct"><%= pct %>%</span>
              </div>
            </td>
            <td class="ta-actions">
              <a class="btn btn-ghost btn-sm" href="/app">Ver pipeline</a>
              <a class="btn btn-ghost btn-sm" href="/app/entregables">Entregables</a>
              <a class="btn btn-ghost btn-sm" href="/app/minutas">Minutas</a>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<%- include('../partials/shell-footer') %>
