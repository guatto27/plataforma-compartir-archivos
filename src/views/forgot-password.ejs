<%- include('partials/header') %>

<div class="auth-card">
  <h1>Recuperar contraseña</h1>
  <p class="muted">Ingresa tu correo electrónico y te enviaremos un enlace para restablecerla.</p>

  <% if (locals.success) { %>
    <div class="flash flash-success">Si el correo está registrado, recibirás un enlace en unos minutos. Revisa también tu carpeta de spam.</div>
    <p style="margin-top:18px"><a href="/login" class="btn btn-ghost btn-block">Volver al inicio de sesión</a></p>
  <% } else { %>
    <% if (locals.error) { %><div class="flash flash-error"><%= error %></div><% } %>
    <form method="post" action="/forgot-password">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label>Correo electrónico
        <input type="email" name="email" required autofocus maxlength="200" placeholder="tucorreo@empresa.com" />
      </label>
      <button class="btn btn-primary btn-block" type="submit">Enviar enlace</button>
    </form>
    <p class="auth-forgot"><a href="/login">Volver al inicio de sesión</a></p>
  <% } %>
</div>

<%- include('partials/footer') %>
