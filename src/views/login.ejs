<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title><%= title %> · <%= brand.name %></title>
  <link rel="icon" type="image/png" href="/static/img/logo-mark.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/static/css/styles.css" />
</head>
<body class="auth2-body">
  <div class="auth2">

    <!-- ── Panel izquierdo: red neuronal dorada ── -->
    <section class="auth2-hero">
      <canvas id="netfx" class="auth2-canvas"></canvas>
      <div class="auth2-hero-vignette"></div>
      <div class="auth2-hero-content">
        <h1 class="auth2-wordmark">BusinessCool<span>&nbsp;AI</span></h1>
        <p class="auth2-tagline"><%= brand.tagline %></p>
      </div>
      <div class="auth2-live">
        <span class="dot"></span> Conexiones de IA activas: <strong id="live-count">1,245,678</strong>
      </div>
    </section>

    <!-- ── Panel derecho: formulario ── -->
    <section class="auth2-form">
      <div class="auth2-card">
        <h2 class="auth2-title">Acceso a la plataforma</h2>

        <% if (error) { %><div class="flash flash-error" style="margin-bottom:18px"><%= error %></div><% } %>

        <form method="post" action="/login" autocomplete="off">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <label class="auth2-label">Usuario
            <input type="text" name="username" required autofocus maxlength="40" />
          </label>
          <label class="auth2-label">Contraseña
            <div class="pw-wrap">
              <input type="password" id="pw-input" name="password" required maxlength="200" />
              <button type="button" class="pw-eye" aria-label="Mostrar contraseña" data-pw-toggle="pw-input">
                <svg class="eye-show" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                <svg class="eye-hide" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
              </button>
            </div>
          </label>
          <button class="btn-gold" type="submit">Entrar</button>
          <p class="auth2-forgot"><a href="/forgot-password">¿Olvidaste tu contraseña?</a></p>
        </form>
      </div>

      <svg class="auth2-spark" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M12 1 L14.2 9.8 L23 12 L14.2 14.2 L12 23 L9.8 14.2 L1 12 L9.8 9.8 Z" fill="currentColor"/>
      </svg>
      <footer class="auth2-foot">© <%= new Date().getFullYear() %> <%= brand.name %> — <%= brand.tagline %> — Todos los derechos reservados</footer>
    </section>

  </div>

  <script src="/static/js/app.js"></script>
  <script src="/static/js/login-fx.js"></script>
</body>
</html>
