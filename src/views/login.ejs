<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title><%= title %> · <%= brand.name %></title>
  <link rel="icon" type="image/png" href="/static/img/logo-mark.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/static/css/styles.css" />
</head>
<body class="auth-body">
  <div class="auth-split">

    <!-- ── Panel izquierdo: logo animado + marca ── -->
    <aside class="auth-hero">
      <div class="auth-hero-bg"></div>
      <div class="auth-hero-inner">
        <div class="auth-logo-anim">
          <span class="ring ring-1"></span>
          <span class="ring ring-2"></span>
          <span class="ring ring-dot"></span>
          <span class="auth-logo-core">
            <img class="auth-logo-img" src="/static/img/logo-mark.png" alt="<%= brand.name %>" />
            <span class="auth-logo-shine"></span>
          </span>
        </div>
        <img class="auth-hero-wordmark" src="/static/img/logo-wordmark.png" alt="<%= brand.name %>" />
        <p class="auth-hero-tag"><%= brand.tagline %></p>
      </div>
    </aside>

    <!-- ── Panel derecho: formulario ── -->
    <main class="auth-form-panel">
      <div class="auth-form-box">
        <a class="auth-brand-mini" href="/">
          <img src="/static/img/logo-mark.png" alt="<%= brand.name %>" width="34" height="34" />
          <span><%= brand.name %></span>
        </a>

        <h1>Acceso a la plataforma</h1>
        <p class="muted">Ingresa con el usuario y la contraseña que te proporcionó <%= brand.name %>.</p>

        <% if (error) { %><div class="flash flash-error" style="margin-bottom:16px"><%= error %></div><% } %>

        <form method="post" action="/login" autocomplete="off">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <label class="auth-label">Usuario
            <input type="text" name="username" required autofocus maxlength="40" />
          </label>
          <label class="auth-label">Contraseña
            <div class="pw-wrap">
              <input type="password" id="pw-input" name="password" required maxlength="200" />
              <button type="button" class="pw-eye" aria-label="Mostrar contraseña" data-pw-toggle="pw-input">
                <svg class="eye-show" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                <svg class="eye-hide" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
              </button>
            </div>
          </label>
          <button class="btn btn-primary btn-block" type="submit" style="margin-top:6px">Entrar</button>
        </form>

        <p class="auth-forgot"><a href="/forgot-password">¿Olvidaste tu contraseña?</a></p>
      </div>

      <footer class="auth-foot">© <%= new Date().getFullYear() %> <%= brand.name %> — <%= brand.tagline %></footer>
    </main>

  </div>
  <script src="/static/js/app.js"></script>
</body>
</html>
