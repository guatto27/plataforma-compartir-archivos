<%- include('partials/header') %>

<div class="auth-card">
  <h1>Cambiar contraseña</h1>
  <% if (forced) { %>
    <p class="muted">Por seguridad, debes definir una nueva contraseña antes de continuar.</p>
  <% } %>

  <% if (error) { %><div class="flash flash-error"><%= error %></div><% } %>

  <form method="post" action="/cambiar-password" autocomplete="off">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <% var eye = '<svg class="eye-show" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg><svg class="eye-hide" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>'; %>
    <label>Contraseña actual
      <div class="pw-wrap">
        <input type="password" id="cp-current" name="current" required maxlength="200" />
        <button type="button" class="pw-eye" aria-label="Mostrar contraseña" data-pw-toggle="cp-current"><%- eye %></button>
      </div>
    </label>
    <label>Nueva contraseña (mínimo 10 caracteres)
      <div class="pw-wrap">
        <input type="password" id="cp-next" name="next" required minlength="10" maxlength="200" />
        <button type="button" class="pw-eye" aria-label="Mostrar contraseña" data-pw-toggle="cp-next"><%- eye %></button>
      </div>
    </label>
    <label>Confirmar nueva contraseña
      <div class="pw-wrap">
        <input type="password" id="cp-confirm" name="confirm" required minlength="10" maxlength="200" />
        <button type="button" class="pw-eye" aria-label="Mostrar contraseña" data-pw-toggle="cp-confirm"><%- eye %></button>
      </div>
    </label>
    <button class="btn btn-primary btn-block" type="submit">Guardar</button>
  </form>
</div>

<%- include('partials/footer') %>
