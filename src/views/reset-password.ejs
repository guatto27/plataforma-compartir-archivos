<%- include('partials/header') %>

<div class="auth-card">
  <h1>Nueva contraseña</h1>

  <% if (locals.expired) { %>
    <div class="flash flash-error">Este enlace ha expirado o ya fue utilizado. Solicita uno nuevo.</div>
    <p style="margin-top:18px"><a href="/forgot-password" class="btn btn-ghost btn-block">Solicitar nuevo enlace</a></p>
  <% } else if (locals.success) { %>
    <div class="flash flash-success">Contraseña actualizada correctamente. Ya puedes iniciar sesión.</div>
    <p style="margin-top:18px"><a href="/login" class="btn btn-primary btn-block">Iniciar sesión</a></p>
  <% } else { %>
    <p class="muted">Elige una contraseña segura de al menos 10 caracteres.</p>
    <% if (locals.error) { %><div class="flash flash-error"><%= error %></div><% } %>
    <form method="post" action="/reset-password/<%= token %>">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label>Nueva contraseña
        <div class="pw-wrap">
          <input type="password" id="pw-input" name="password" required minlength="10" maxlength="200" />
          <button type="button" class="pw-eye" aria-label="Mostrar contraseña" data-pw-toggle="pw-input">
            <svg class="eye-show" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            <svg class="eye-hide" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
          </button>
        </div>
      </label>
      <label>Confirmar contraseña
        <div class="pw-wrap">
          <input type="password" id="pw-confirm" name="confirm" required minlength="10" maxlength="200" />
          <button type="button" class="pw-eye" aria-label="Mostrar contraseña" data-pw-toggle="pw-confirm">
            <svg class="eye-show" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            <svg class="eye-hide" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
          </button>
        </div>
      </label>
      <button class="btn btn-primary btn-block" type="submit">Guardar contraseña</button>
    </form>
  <% } %>
</div>


<%- include('partials/footer') %>
