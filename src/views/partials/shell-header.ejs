<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title><%= title %> · <%= brand.name %></title>
  <script src="/static/js/theme.js"></script>
  <link rel="icon" type="image/png" href="/static/img/logo-mark.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/static/css/styles.css" />
</head>
<%
  var role = currentUser ? currentUser.role : 'client';
  var isClient = role === 'client' || role === 'cliente_responsable';
  var isAdmin  = role === 'admin';
  var isColab  = role === 'colaborador';
  var isStaff  = isAdmin || isColab;
  var homeBase = isStaff ? '/admin' : '/app';
  var act = (typeof active !== 'undefined') ? active : '';
  var roleLabel = isAdmin ? 'Administrador' : (isColab ? 'Colaborador' : (role === 'cliente_responsable' ? 'Cliente responsable' : 'Parte interesada'));
  // Menú superior: clientes (Inicio/¿Quiénes somos?[/Proyectos]) y admin (solo Panel)
  var showTopnav = isClient || isAdmin;
  var topnavBase = isAdmin ? '/admin' : '/app';
  // Flecha del árbol de fases (reusada por cliente y admin)
  var caret = '<span class="tree-caret-btn" data-tree-toggle><svg class="tree-caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></span>';
%>
<body class="has-sidebar">
  <aside class="sidebar">
    <a class="sidebar-brand" href="<%= homeBase %>">
      <img src="/static/img/logo-mark.png" alt="<%= brand.name %>" width="34" height="34" />
      <span>
        <img class="sidebar-wordmark wm-dark" src="/static/img/logo-wordmark.png" alt="<%= brand.name %>" />
        <img class="sidebar-wordmark wm-light" src="/static/img/logo-wordmark-dark.png" alt="<%= brand.name %>" />
        <small><%= brand.tagline %></small>
      </span>
    </a>

    <% if (showTopnav) { %>
      <!-- Menú superior dentro del cajón (solo celular) -->
      <nav class="sidebar-topnav">
        <a href="<%= topnavBase %>/inicio" class="<%= act === 'inicio' ? 'active' : '' %>"><%= isAdmin ? 'Panel' : 'Inicio' %></a>
        <% if (!isAdmin) { %>
          <a href="<%= topnavBase %>/nosotros" class="<%= act === 'nosotros' ? 'active' : '' %>">¿Quiénes somos?</a>
        <% } %>
        <% if (role === 'cliente_responsable') { %>
          <a href="<%= topnavBase %>/proyectos" class="<%= act === 'proyectos' ? 'active' : '' %>">Proyectos</a>
        <% } %>
      </nav>
    <% } %>

    <% if (isClient) { %>
      <!-- ────────── Menú CLIENTE (responsable y usuario): fases plegables ────────── -->
      <% var f1Active = (act === 'proyecto' || act === 'agente' || act === 'entregables' || act === 'archivos-empresa' || act === 'informacion'); %>
      <% if (typeof sidebarProjects !== 'undefined' && sidebarProjects && sidebarProjects.length) { %>
        <div class="sidebar-section">Proyecto</div>
        <form method="get" action="/app/seleccionar" class="sidebar-project">
          <select name="id" data-autosubmit aria-label="Seleccionar proyecto">
            <% sidebarProjects.forEach(function (p) { %>
              <option value="<%= p.id %>" <%= p.id === activeProjectId ? 'selected' : '' %>><%= p.name %></option>
            <% }) %>
          </select>
          <noscript><button type="submit" class="btn btn-ghost btn-sm">Ver</button></noscript>
        </form>
      <% } %>
      <% if (role === 'cliente_responsable') { %>
        <nav class="sidebar-nav" style="margin-top:6px">
          <a href="/app/minutas" class="<%= act === 'minutas' ? 'active' : '' %>">
            <span class="nav-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.12 2.12 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            </span>
            Gestión de Minutas y Contratos
          </a>
        </nav>
      <% } %>
      <div class="sidebar-section">Fases del proyecto</div>
      <nav class="sidebar-nav sidebar-tree">

        <details class="nav-phase"<%= f1Active ? ' open' : '' %>>
          <summary data-href="/app" class="<%= act === 'proyecto' ? 'is-current' : '' %>"><span class="phase-title" title="F1 Diagnóstico y Levantamiento">F1 Diagnóstico y Levantamiento</span><%- caret %></summary>
          <div class="phase-body">
            <div class="tree-group-label">Actividades</div>
            <div class="tree-group">
              <% if (role === 'cliente_responsable') { %>
                <a href="/app/informacion" class="<%= act === 'informacion' ? 'active' : '' %>" title="Información requerida">Información requerida</a>
              <% } %>
              <a href="/app/agente" class="<%= (act === 'agente' || act === 'archivos-empresa') ? 'active' : '' %>" title="Entrevistas y Encuesta IMA">Entrevistas y Encuesta IMA</a>
              <% if (role === 'cliente_responsable') { %>
                <span class="tree-info" title="Mapeo de Procesos Actuales (AS-IS)">Mapeo de Procesos Actuales (AS-IS)</span>
                <span class="tree-info" title="Informe de Integración de Hallazgos">Informe de Integración de Hallazgos</span>
                <span class="tree-info" title="Mapeo de Proceso Deseado (TO-BE)">Mapeo de Proceso Deseado (TO-BE)</span>
              <% } %>
            </div>
            <% if (role === 'cliente_responsable') { %>
              <a href="/app/entregables" class="tree-leaf <%= act === 'entregables' ? 'active' : '' %>" title="Entregables">Entregables</a>
            <% } %>
          </div>
        </details>

        <% if (role === 'cliente_responsable') { %>
        <details class="nav-phase">
          <summary><span class="phase-title" title="F2 Diseño y Arquitectura (Construcción)">F2 Diseño y Arquitectura (Construcción)</span><%- caret %></summary>
          <div class="phase-body">
            <a href="/app/entregables" class="tree-leaf" title="Entregables">Entregables</a>
          </div>
        </details>

        <details class="nav-phase">
          <summary><span class="phase-title" title="F3 QA Final, Validación y Lanzamiento">F3 QA Final, Validación y Lanzamiento</span><%- caret %></summary>
          <div class="phase-body">
            <a href="/app/entregables" class="tree-leaf" title="Entregables">Entregables</a>
          </div>
        </details>

        <details class="nav-phase">
          <summary><span class="phase-title" title="F4 Operatividad, Soporte y Seguimiento">F4 Operatividad, Soporte y Seguimiento</span><%- caret %></summary>
          <div class="phase-body">
            <a href="/app/entregables" class="tree-leaf" title="Entregables">Entregables</a>
          </div>
        </details>
        <% } %>

      </nav>

    <% } else if (isAdmin) { %>
      <!-- ────────── Menú ADMINISTRADOR ────────── -->
      <div class="sidebar-section">Administración</div>
      <nav class="sidebar-nav">
        <a href="/admin/empresas" class="<%= act === 'empresas' ? 'active' : '' %>">
          <span class="nav-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
          </span>
          Empresas/Clientes
        </a>
        <a href="/admin/usuarios" class="<%= act === 'usuarios' ? 'active' : '' %>">
          <span class="nav-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </span>
          Gestión de Usuarios
        </a>
        <a href="/admin/proyectos" class="<%= act === 'proyectos' ? 'active' : '' %>">
          <span class="nav-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
          </span>
          Proyectos
        </a>
        <a href="/admin/minutas" class="<%= act === 'minutas' ? 'active' : '' %>">
          <span class="nav-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.12 2.12 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          </span>
          Gestión de Minutas y Contratos
        </a>
      </nav>

      <% if (typeof adminProjects !== 'undefined' && adminProjects && adminProjects.length) { %>
        <div class="sidebar-section">Proyecto</div>
        <form method="get" action="/admin/seleccionar" class="sidebar-project">
          <select name="id" data-autosubmit aria-label="Seleccionar proyecto">
            <option value="">— Selecciona un proyecto —</option>
            <% adminProjects.forEach(function (p) { %>
              <option value="<%= p.id %>" <%= p.id === adminProjectId ? 'selected' : '' %>><%= p.company_name %> — <%= p.name %></option>
            <% }) %>
          </select>
          <noscript><button type="submit" class="btn btn-ghost btn-sm">Ver</button></noscript>
        </form>

        <% if (adminProjectId) { %>
          <% var pq = '?proyecto=' + adminProjectId; %>
          <div class="sidebar-section">Fases del proyecto</div>
          <nav class="sidebar-nav sidebar-tree">
            <details class="nav-phase"<%= (act === 'entrevistas' || act === 'informacion') ? ' open' : '' %>>
              <summary data-href="/admin<%= pq %>" class="<%= act === 'entrevistas' ? 'is-current' : '' %>"><span class="phase-title" title="F1 Diagnóstico y Levantamiento">F1 Diagnóstico y Levantamiento</span><%- caret %></summary>
              <div class="phase-body">
                <div class="tree-group-label">Actividades</div>
                <div class="tree-group">
                  <a href="/admin/informacion<%= pq %>" class="<%= act === 'informacion' ? 'active' : '' %>" title="Información requerida">Información requerida</a>
                  <a href="/admin<%= pq %>" class="<%= act === 'entrevistas' ? 'active' : '' %>" title="Entrevistas y Encuesta IMA">Entrevistas y Encuesta IMA</a>
                  <span class="tree-info" title="Mapeo de Procesos Actuales (AS-IS)">Mapeo de Procesos Actuales (AS-IS)</span>
                  <span class="tree-info" title="Informe de Integración de Hallazgos">Informe de Integración de Hallazgos</span>
                  <span class="tree-info" title="Mapeo de Proceso Deseado (TO-BE)">Mapeo de Proceso Deseado (TO-BE)</span>
                </div>
                <a href="/admin/archivos<%= pq %>" class="tree-leaf" title="Entregables / Archivos">Entregables / Archivos</a>
              </div>
            </details>
            <details class="nav-phase">
              <summary><span class="phase-title" title="F2 Diseño y Arquitectura (Construcción)">F2 Diseño y Arquitectura (Construcción)</span><%- caret %></summary>
              <div class="phase-body"><a href="/admin/archivos<%= pq %>" class="tree-leaf" title="Entregables">Entregables</a></div>
            </details>
            <details class="nav-phase">
              <summary><span class="phase-title" title="F3 QA Final, Validación y Lanzamiento">F3 QA Final, Validación y Lanzamiento</span><%- caret %></summary>
              <div class="phase-body"><a href="/admin/archivos<%= pq %>" class="tree-leaf" title="Entregables">Entregables</a></div>
            </details>
            <details class="nav-phase">
              <summary><span class="phase-title" title="F4 Operatividad, Soporte y Seguimiento">F4 Operatividad, Soporte y Seguimiento</span><%- caret %></summary>
              <div class="phase-body"><a href="/admin/archivos<%= pq %>" class="tree-leaf" title="Entregables">Entregables</a></div>
            </details>
          </nav>
        <% } %>
      <% } %>

    <% } else { %>
      <!-- ────────── Menú COLABORADOR ────────── -->
      <div class="sidebar-section">Equipo</div>
      <nav class="sidebar-nav">
        <a href="/admin" class="<%= act === 'entrevistas' ? 'active' : '' %>">
          <span class="nav-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </span>
          Clientes
        </a>
        <a href="/admin/archivos" class="<%= act === 'archivos' ? 'active' : '' %>">
          <span class="nav-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
          </span>
          Archivos
        </a>
        <a href="/admin/empresas" class="<%= act === 'empresas' ? 'active' : '' %>">
          <span class="nav-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
          </span>
          Empresas
        </a>
        <a href="/admin/usuarios" class="<%= act === 'usuarios' ? 'active' : '' %>">
          <span class="nav-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </span>
          Usuarios
        </a>
      </nav>
    <% } %>
  </aside>
  <div class="sidebar-backdrop" data-sidebar-close></div>

  <div class="shell-main">
    <header class="topbar-2">
      <div class="topbar-left">
        <% if (currentUser) { %>
          <button class="nav-toggle" type="button" data-sidebar-toggle aria-label="Abrir menú">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          </button>
        <% } %>
        <% if (showTopnav) { %>
          <nav class="topnav">
            <a href="<%= topnavBase %>/inicio" class="<%= act === 'inicio' ? 'active' : '' %>"><%= isAdmin ? 'Panel' : 'Inicio' %></a>
            <% if (!isAdmin) { %>
              <a href="<%= topnavBase %>/nosotros" class="<%= act === 'nosotros' ? 'active' : '' %>">¿Quiénes somos?</a>
            <% } %>
            <% if (role === 'cliente_responsable') { %>
              <a href="<%= topnavBase %>/proyectos" class="<%= act === 'proyectos' ? 'active' : '' %>">Proyectos</a>
            <% } %>
          </nav>
        <% } %>
      </div>
      <% if (currentUser) { %>
        <div class="topbar-actions">
          <div class="topbar-search" data-search-box>
            <input type="search" class="topbar-search-input" placeholder="Buscar página, sección, empresa…" data-search-input aria-label="Buscar en el portal" autocomplete="off" />
            <button class="topbar-icon" type="button" data-search-toggle title="Buscar" aria-label="Buscar">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            </button>
            <div class="topbar-search-results" data-search-results hidden></div>
          </div>
          <button class="topbar-icon" type="button" data-dialog="dlg-info" title="Información" aria-label="Información">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
          </button>
          <button class="topbar-icon notif-bell" type="button" data-dialog="dlg-notif" title="Notificaciones" aria-label="Notificaciones">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
            <% if (typeof notifUnread !== 'undefined' && notifUnread > 0) { %><span class="notif-badge"><%= notifUnread > 9 ? '9+' : notifUnread %></span><% } %>
          </button>
          <button class="topbar-icon" type="button" data-dialog="dlg-ayuda" title="Asistencia" aria-label="Asistencia">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          </button>
          <details class="usermenu">
            <summary class="usercard" title="<%= currentUser.displayName %>">
              <span class="usercard-info">
                <strong><%= currentUser.displayName %></strong>
                <small><%= currentUser.companyName || brand.name %></small>
              </span>
              <span class="avatar"><%= (currentUser.displayName || '?').charAt(0).toUpperCase() %></span>
            </summary>
            <div class="usermenu-pop">
              <div class="usermenu-name"><%= currentUser.displayName %> · <%= roleLabel %></div>
              <button type="button" class="usermenu-item" data-dialog="dlg-perfil">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                Perfil
              </button>
              <form method="post" action="/logout">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button type="submit" class="usermenu-item">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
                  Cambiar cuenta
                </button>
              </form>
              <button type="button" class="usermenu-item is-toggle" data-theme-toggle>
                <span style="display:flex;align-items:center;gap:8px">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a9 9 0 1 0 9 9c0-.46-.04-.92-.1-1.36a5.39 5.39 0 0 1-4.4 2.26 5.38 5.38 0 0 1-3.95-9.06A9.1 9.1 0 0 0 12 3z"/></svg>
                  Tema
                </span>
                <span class="theme-state" data-theme-label>Oscuro</span>
              </button>
              <div class="usermenu-sep"></div>
              <form method="post" action="/logout">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button type="submit" class="usermenu-item">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                  Cerrar sesión
                </button>
              </form>
            </div>
          </details>
        </div>
      <% } %>
    </header>

    <% if (currentUser) { %>
      <dialog id="dlg-info" class="modal">
        <h2>Acerca de la plataforma</h2>
        <p class="muted" style="margin-top:4px">Plataforma de <%= brand.name %> para el levantamiento, la gestión de archivos y las minutas de tus proyectos de IA.</p>
        <dl class="dlg-info-row">
          <dt>Plataforma</dt><dd><%= brand.name %></dd>
          <dt>Sitio</dt><dd><a href="<%= brand.website %>" target="_blank" rel="noopener"><%= brand.website %></a></dd>
        </dl>
        <div class="modal-actions"><button class="btn btn-ghost" type="button" data-close>Cerrar</button></div>
      </dialog>

      <dialog id="dlg-notif" class="modal">
        <div class="head-row" style="margin-bottom:8px">
          <h2 style="margin:0">Notificaciones</h2>
          <% if (typeof notifUnread !== 'undefined' && notifUnread > 0) { %>
            <form method="post" action="/notificaciones/leer" class="inline">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <button class="btn btn-ghost btn-sm" type="submit">Marcar como leídas</button>
            </form>
          <% } %>
        </div>
        <% if (!notifs || !notifs.length) { %>
          <div class="dlg-empty">No tienes notificaciones nuevas.</div>
        <% } else { %>
          <ul class="notif-list">
            <% notifs.forEach(function (n) { %>
              <li class="notif-item<%= n.is_read ? '' : ' unread' %>">
                <a href="<%= n.link ? ('/notificaciones/ir/' + n.id) : '#' %>">
                  <strong><%= n.title %></strong>
                  <% if (n.body) { %><span class="notif-body"><%= n.body %></span><% } %>
                  <span class="notif-time"><%= fmtDate ? fmtDate(n.created_at) : n.created_at %></span>
                </a>
              </li>
            <% }) %>
          </ul>
        <% } %>
        <div class="modal-actions"><button class="btn btn-ghost" type="button" data-close>Cerrar</button></div>
      </dialog>

      <dialog id="dlg-ayuda" class="modal">
        <h2>Asistencia</h2>
        <p class="muted" style="margin-top:4px">¿Necesitas ayuda? Contacta a tu equipo de <%= brand.name %>.</p>
        <dl class="dlg-info-row">
          <dt>Sitio</dt><dd><a href="<%= brand.website %>" target="_blank" rel="noopener"><%= brand.website %></a></dd>
        </dl>
        <div class="modal-actions"><button class="btn btn-ghost" type="button" data-close>Cerrar</button></div>
      </dialog>

      <dialog id="dlg-perfil" class="modal">
        <h2>Mi perfil</h2>
        <dl class="dlg-info-row">
          <dt>Nombre</dt><dd><%= currentUser.displayName %></dd>
          <dt>Usuario</dt><dd><%= currentUser.username %></dd>
          <dt>Rol</dt><dd><%= roleLabel %></dd>
        </dl>
        <div class="modal-actions"><button class="btn btn-ghost" type="button" data-close>Cerrar</button></div>
      </dialog>
    <% } %>
    <main class="shell-content">
      <%
        var menuPages = ['inicio', 'proyectos', 'nosotros'];
        var hideProject = menuPages.indexOf(act) !== -1;   // sin "Proyecto:" en el menú superior
        var brandOnly = act === 'nosotros' || act === 'inicio'; // solo BusinessCool, centrado
      %>
      <% if (isClient && currentUser) { %>
        <% if (brandOnly) { %>
          <div class="client-banner">
            <div class="cb-brand-only">
              <img class="cb-icon" src="/static/img/logo-mark.png" alt="<%= brand.name %>" />
              <img class="cb-wordmark wm-dark" src="/static/img/logo-wordmark.png" alt="<%= brand.name %>" />
              <img class="cb-wordmark wm-light" src="/static/img/logo-wordmark-dark.png" alt="<%= brand.name %>" />
            </div>
          </div>
        <% } else { %>
          <div class="client-banner">
            <div class="cb-row">
              <!-- Empresa: BusinessCool -->
              <div class="cb-company">
                <div class="cb-logo-row">
                  <img class="cb-icon" src="/static/img/logo-mark.png" alt="<%= brand.name %>" />
                </div>
                <div class="cb-name-row">
                  <img class="cb-wordmark wm-dark" src="/static/img/logo-wordmark.png" alt="<%= brand.name %>" />
                  <img class="cb-wordmark wm-light" src="/static/img/logo-wordmark-dark.png" alt="<%= brand.name %>" />
                </div>
              </div>
              <span class="cb-divider"></span>
              <!-- Empresa: cliente -->
              <div class="cb-company">
                <div class="cb-logo-row">
                  <% if (currentUser.companyHasLogo) { %>
                    <img class="cb-comp-logo" src="/app/empresa/logo" alt="<%= currentUser.companyName %>" />
                  <% } %>
                </div>
                <div class="cb-name-row">
                  <% if (currentUser.companyHasEslogan) { %>
                    <img class="cb-eslogan-img" src="/app/empresa/eslogan" alt="<%= currentUser.companyName %>" />
                  <% } else if (currentUser.companyName) { %>
                    <span class="cb-comp-name"><%= currentUser.companyName %></span>
                  <% } %>
                </div>
              </div>
            </div>
            <% if (currentUser.companyProject && !hideProject) { %>
              <div class="cb-project"><strong>Proyecto:</strong> <%= currentUser.companyProject %></div>
            <% } %>
          </div>
        <% } %>
      <% } %>
      <%- include('flash') %>
