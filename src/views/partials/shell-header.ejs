<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title><%= title %> · <%= brand.name %></title>
  <link rel="icon" type="image/svg+xml" href="/static/img/logo.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/static/css/styles.css" />
</head>
<%
  var role = currentUser ? currentUser.role : 'client';
  var isClient = role === 'client' || role === 'cliente_responsable';
  var isAdmin  = role === 'admin';
  var isColab  = role === 'colaborador';
  var isStaff  = isAdmin || isColab;
  var homeBase = isStaff ? '/admin' : '/app';
  var act = (typeof active !== 'undefined') ? active : '';
%>
<body class="has-sidebar">
  <aside class="sidebar">
    <a class="sidebar-brand" href="<%= homeBase %>">
      <img src="/static/img/logo.svg" alt="<%= brand.name %>" width="34" height="34" />
      <span>
        <strong><%= brand.name %></strong>
        <small><%= brand.tagline %></small>
      </span>
    </a>

    <% if (isClient) { %>
      <!-- ────────── Menú CLIENTE ────────── -->
      <div class="sidebar-section">Cliente</div>
      <nav class="sidebar-nav">
        <a href="/app" class="<%= act === 'proyecto' ? 'active' : '' %>">
          <span class="nav-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
          </span>
          Mi proyecto
        </a>
        <a href="/app/entregables" class="<%= act === 'entregables' ? 'active' : '' %>">
          <span class="nav-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          </span>
          Entregables
          <% if (typeof entregablesCount !== 'undefined' && entregablesCount) { %><span class="count-badge"><%= entregablesCount %></span><% } %>
        </a>
        <a href="/app/minutas" class="<%= act === 'minutas' ? 'active' : '' %>">
          <span class="nav-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.12 2.12 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          </span>
          Minutas
        </a>
        <a href="/app/agente" class="<%= act === 'agente' ? 'active' : '' %>">
          <span class="nav-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 1 0-16 0"/></svg>
          </span>
          Agente de levantamiento
        </a>
      </nav>

    <% } else if (isAdmin) { %>
      <!-- ────────── Menú ADMINISTRADOR ────────── -->
      <div class="sidebar-section">Administración</div>
      <nav class="sidebar-nav">
        <a href="/admin" class="<%= act === 'entrevistas' ? 'active' : '' %>">
          <span class="nav-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </span>
          Clientes
        </a>
        <a href="/admin/archivos" class="<%= act === 'archivos' ? 'active' : '' %>">
          <span class="nav-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
          </span>
          Archivos
        </a>
        <a href="/admin/empresas" class="<%= act === 'empresas' ? 'active' : '' %>">
          <span class="nav-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
          </span>
          Gestión de Empresas/Clientes
        </a>
        <a href="/admin/usuarios" class="<%= act === 'usuarios' ? 'active' : '' %>">
          <span class="nav-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </span>
          Gestión de Usuarios
        </a>
      </nav>

    <% } else { %>
      <!-- ────────── Menú COLABORADOR ────────── -->
      <div class="sidebar-section">Equipo</div>
      <nav class="sidebar-nav">
        <a href="/admin" class="<%= act === 'entrevistas' ? 'active' : '' %>">
          <span class="nav-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </span>
          Clientes
        </a>
        <a href="/admin/archivos" class="<%= act === 'archivos' ? 'active' : '' %>">
          <span class="nav-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
          </span>
          Archivos
        </a>
        <a href="/admin/empresas" class="<%= act === 'empresas' ? 'active' : '' %>">
          <span class="nav-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
          </span>
          Empresas
        </a>
        <a href="/admin/usuarios" class="<%= act === 'usuarios' ? 'active' : '' %>">
          <span class="nav-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </span>
          Usuarios
        </a>
      </nav>
    <% } %>
  </aside>

  <div class="shell-main">
    <header class="topbar-2">
      <div></div>
      <% if (currentUser) { %>
        <nav class="nav">
          <details class="usermenu">
            <summary class="avatar" title="<%= currentUser.displayName %>"><%= (currentUser.displayName || '?').charAt(0).toUpperCase() %></summary>
            <div class="usermenu-pop">
              <div class="usermenu-name"><%= currentUser.displayName %></div>
              <a href="/cambiar-password">Cambiar mi contraseña</a>
              <form method="post" action="/logout">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button type="submit" class="usermenu-item">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                  Salir
                </button>
              </form>
            </div>
          </details>
        </nav>
      <% } %>
    </header>
    <main class="shell-content">
      <%- include('flash') %>
