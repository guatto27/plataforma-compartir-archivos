<%
  var base = currentUser.role === 'admin' ? '/admin' : '/app';
  var isAdmin = currentUser.role === 'admin';
%>
<div class="table-wrap">
  <table class="table files-table">
    <thead>
      <tr>
        <th>Nombre del archivo</th>
        <th>Propietario</th>
        <% if (isAdmin) { %><th>Cliente</th><% } %>
        <th>Entrevista</th>
        <th class="nowrap">Fecha de carga</th>
        <th class="nowrap">Tamaño</th>
        <th class="ta-actions">Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% if (!files.length) { %>
        <tr><td colspan="<%= isAdmin ? 7 : 6 %>" class="empty">Aún no hay archivos. Usa “Agregar” para subir el primero.</td></tr>
      <% } %>
      <% files.forEach(function (f) { %>
        <tr>
          <td class="fname">
            <%= f.original_name %>
            <% if (f.description) { %><div class="meta"><%= f.description %></div><% } %>
          </td>
          <td>
            <%= f.owner_name || f.owner_username || '—' %>
            <% if (f.owner_role === 'admin') { %><span class="tag">consultor</span><% } %>
          </td>
          <% if (isAdmin) { %><td><%= f.client_name || f.client_username || '—' %></td><% } %>
          <td><%= f.interview_nombre || '—' %></td>
          <td class="nowrap meta"><%= fmtDate(f.created_at) %></td>
          <td class="nowrap meta"><%= fmtSize(f.size) %></td>
          <td class="ta-actions">
            <a class="iconbtn" href="<%= base %>/file/<%= f.id %>/view" target="_blank" rel="noopener noreferrer" title="Visualizar" aria-label="Visualizar">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </a>
            <a class="iconbtn" href="<%= base %>/file/<%= f.id %>/comments" title="Comentarios" aria-label="Comentarios">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-8.5 8.5 8.5 8.5 0 0 1-3.8-.9L3 21l1.9-5.7A8.38 8.38 0 0 1 4 11.5 8.5 8.5 0 0 1 12.5 3 8.38 8.38 0 0 1 21 11.5z"/></svg>
              <% if (f.comment_count > 0) { %><span class="count"><%= f.comment_count %></span><% } %>
            </a>
            <% if (f.uploaded_by === currentUser.id) { %>
              <form method="post" action="<%= base %>/file/<%= f.id %>/delete" class="inline" data-confirm="¿Eliminar “<%= f.original_name %>”? Esta acción no se puede deshacer.">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button class="iconbtn danger" type="submit" title="Eliminar" aria-label="Eliminar">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                </button>
              </form>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
