<%- include('../partials/shell-header') %>

<div class="page-head">
  <div class="head-row">
    <div>
      <h1>Proyectos</h1>
      <p class="muted">Todos los proyectos de todas las empresas, con su estatus y actividad.</p>
    </div>
    <% if (canManage) { %>
      <button class="btn btn-primary" type="button" data-dialog="dlg-new-project">+ Nuevo proyecto</button>
    <% } %>
  </div>
</div>

<section class="card">
  <% if (!rows || !rows.length) { %>
    <p class="empty">Aún no hay proyectos. Usa “+ Nuevo proyecto” para dar de alta el primero (la empresa debe estar registrada antes).</p>
  <% } else { %>
    <div class="table-wrap">
      <table class="table">
        <thead>
          <tr>
            <th>Proyecto</th>
            <th>Empresa</th>
            <th class="ta-center">Estatus</th>
            <th class="ta-center">Entregables</th>
            <th class="ta-center">Minutas</th>
            <th class="ta-center">Entrevistas</th>
            <th class="ta-center">Contrato</th>
            <% if (canManage) { %><th class="ta-actions">Acciones</th><% } %>
          </tr>
        </thead>
        <tbody>
          <% rows.forEach(function (r) { %>
            <% var stCls = r.status === 'Finalizado' ? 'st-fin' : (r.status === 'En pausa' ? 'st-pau' : 'st-vig'); %>
            <tr>
              <td class="fname"><strong><%= r.name %></strong></td>
              <td><%= r.company %></td>
              <td class="ta-center"><span class="st-chip <%= stCls %>"><%= r.status %></span></td>
              <td class="ta-center"><%= r.files %></td>
              <td class="ta-center"><%= r.minutas %></td>
              <td class="ta-center"><%= r.interviews %></td>
              <td class="ta-center">
                <% if (!r.contrato_path) { %>
                  <% if (canManage) { %><button class="btn btn-ghost btn-sm" type="button" data-dialog="dlg-contrato-<%= r.id %>">+ Subir</button><% } else { %><span class="meta">—</span><% } %>
                <% } else { %>
                  <button class="btn btn-ghost btn-sm" type="button" data-dialog="dlg-contrato-<%= r.id %>" style="display:inline-flex;align-items:center;gap:6px">
                    <% if (r.cont_firmada && r.cont_firmada_cliente) { %><span class="st-chip st-fin">Firmado</span>
                    <% } else if (r.contrato_enviado) { %><span class="st-chip st-vig">Con el cliente</span>
                    <% } else if (r.cont_firmada) { %><span class="st-chip st-vig">Firma BC</span>
                    <% } else { %><span class="st-chip st-pau">Sin firmar</span><% } %>
                  </button>
                <% } %>
              </td>
              <% if (canManage) { %>
              <td class="ta-actions">
                <button class="iconbtn" type="button" data-dialog="dlg-edit-proj-<%= r.id %>" title="Editar" aria-label="Editar">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z"/></svg>
                </button>
                <form method="post" action="/admin/proyectos/<%= r.id %>/delete" class="inline" data-confirm="¿Eliminar el proyecto “<%= r.name %>”? (Solo si no tiene minutas/entrevistas.)">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <input type="hidden" name="back" value="/admin/proyectos" />
                  <button class="iconbtn danger" type="submit" title="Eliminar" aria-label="Eliminar">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                  </button>
                </form>
              </td>
              <% } %>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<% if (canManage) { %>
  <!-- Alta de proyecto -->
  <dialog id="dlg-new-project" class="modal" data-strict <%= (typeof openNew !== 'undefined' && openNew) ? 'data-autoopen' : '' %>>
    <h2>Nuevo proyecto</h2>
    <form method="post" action="/admin/proyectos">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label>Empresa
        <select name="company_id" required>
          <option value="">— Selecciona la empresa —</option>
          <% companies.forEach(function (c) { %>
            <option value="<%= c.id %>"><%= c.name %></option>
          <% }) %>
        </select>
        <% if (!companies.length) { %><span class="meta" style="display:block;margin-top:4px">Primero registra una empresa en <a href="/admin/empresas">Empresas/Clientes</a>.</span><% } %>
      </label>
      <label>Nombre del proyecto
        <input type="text" name="name" required maxlength="160" placeholder="ej. Validación de Franquicias" />
      </label>
      <label>Estatus
        <select name="status">
          <% PROJ_STATUSES.forEach(function (s) { %><option value="<%= s %>"><%= s %></option><% }) %>
        </select>
      </label>
      <div class="modal-actions">
        <button class="btn btn-primary" type="submit">Crear proyecto</button>
        <button class="btn btn-ghost" type="button" data-close>Cancelar</button>
      </div>
    </form>
  </dialog>

  <!-- Editar cada proyecto -->
  <% rows.forEach(function (r) { %>
    <dialog id="dlg-edit-proj-<%= r.id %>" class="modal" data-strict>
      <h2>Editar proyecto</h2>
      <p class="meta"><%= r.company %></p>
      <form method="post" action="/admin/proyectos/<%= r.id %>/edit">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input type="hidden" name="back" value="/admin/proyectos" />
        <label>Nombre del proyecto
          <input type="text" name="name" value="<%= r.name %>" required maxlength="160" />
        </label>
        <label>Estatus
          <select name="status">
            <% PROJ_STATUSES.forEach(function (s) { %><option value="<%= s %>" <%= r.status === s ? 'selected' : '' %>><%= s %></option><% }) %>
          </select>
        </label>
        <div class="modal-actions">
          <button class="btn btn-primary" type="submit">Guardar cambios</button>
          <button class="btn btn-ghost" type="button" data-close>Cancelar</button>
        </div>
      </form>
    </dialog>
  <% }) %>

  <!-- Contrato de cada proyecto -->
  <% rows.forEach(function (r) { %>
    <dialog id="dlg-contrato-<%= r.id %>" class="modal firma-modal">
      <div class="head-row" style="margin-bottom:10px">
        <div><h2 style="margin:0">Contrato del proyecto</h2><p class="meta" style="margin:2px 0 0"><%= r.name %> · <%= r.company %></p></div>
        <button class="btn btn-ghost btn-sm" type="button" data-close>Cerrar</button>
      </div>

      <% if (!r.contrato_path) { %>
        <p class="muted" style="font-size:13px">Sube el contrato en PDF para firmarlo con tu e.firma y enviarlo al cliente responsable para su firma.</p>
        <form method="post" action="/admin/proyectos/<%= r.id %>/contrato" enctype="multipart/form-data">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <label>Archivo del contrato (PDF)
            <input type="file" name="contrato" accept=".pdf" required />
          </label>
          <div class="modal-actions">
            <button class="btn btn-primary" type="submit">Subir contrato</button>
            <button class="btn btn-ghost" type="button" data-close>Cancelar</button>
          </div>
        </form>
      <% } else { %>
        <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:12px">
          <span class="st <%= r.cont_firmada ? 'aprob' : 'rev' %>"><%= r.cont_firmada ? '✓ Firmado por BusinessCool' : 'Pendiente firma BusinessCool' %></span>
          <span class="st <%= r.cont_firmada_cliente ? 'aprob' : 'rev' %>"><%= r.cont_firmada_cliente ? '✓ Firmado por el cliente' : 'Pendiente firma del cliente' %></span>
          <% if (r.contrato_enviado) { %><span class="st rev">Enviado al cliente</span><% } %>
        </div>

        <object class="minuta-pdf-view" data-pdf-src="/admin/proyectos/<%= r.id %>/contrato/ver-pdf" type="application/pdf">
          <p class="muted">No se pudo mostrar el PDF. <a href="/admin/proyectos/<%= r.id %>/contrato/ver-pdf" target="_blank" rel="noopener noreferrer">Ábrelo en una pestaña</a>.</p>
        </object>

        <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:12px">
          <a class="btn btn-ghost btn-sm" href="/admin/proyectos/<%= r.id %>/contrato/descargar">Descargar</a>
          <% if (r.cont_firmada) { %>
            <form method="post" action="/admin/proyectos/<%= r.id %>/contrato/enviar" class="inline">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <button class="btn <%= r.contrato_enviado ? 'btn-ghost' : 'btn-primary' %> btn-sm" type="submit"><%= r.contrato_enviado ? 'Retirar del cliente' : 'Enviar al cliente responsable' %></button>
            </form>
          <% } %>
          <form method="post" action="/admin/proyectos/<%= r.id %>/contrato/eliminar" class="inline" data-confirm="¿Eliminar el contrato de este proyecto?">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button class="btn btn-ghost btn-sm" type="submit" style="color:var(--bc-error)">Eliminar</button>
          </form>
        </div>

        <% if (!r.cont_firmada) { %>
          <hr style="border:none;border-top:1px solid var(--bc-border);margin:16px 0" />
          <h3 style="margin:0 0 6px">Firmar con e.firma (SAT)</h3>
          <p class="muted" style="font-size:12px;margin-bottom:10px">La firma se coloca automáticamente. Los archivos .key/.cer <strong>nunca se almacenan</strong>.</p>
          <form method="post" action="/admin/proyectos/<%= r.id %>/contrato/firmar" enctype="multipart/form-data">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <label>Archivo .key (llave privada) <input type="file" name="key_file" accept=".key" required /></label>
            <label>Archivo .cer (certificado) <input type="file" name="cer_file" accept=".cer" required /></label>
            <label>Contraseña de e.firma <input type="password" name="passphrase" required maxlength="100" placeholder="Contraseña del SAT" /></label>
            <div class="modal-actions"><button class="btn btn-primary" type="submit">Firmar contrato</button></div>
          </form>
        <% } %>

        <hr style="border:none;border-top:1px solid var(--bc-border);margin:16px 0" />
        <details>
          <summary class="muted" style="cursor:pointer;font-size:13px">Reemplazar el contrato por otro PDF</summary>
          <form method="post" action="/admin/proyectos/<%= r.id %>/contrato" enctype="multipart/form-data" style="margin-top:10px">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <label><input type="file" name="contrato" accept=".pdf" required /></label>
            <div class="modal-actions"><button class="btn btn-ghost btn-sm" type="submit">Subir nuevo (reinicia firmas)</button></div>
          </form>
        </details>
      <% } %>
    </dialog>
  <% }) %>
<% } %>

<%- include('../partials/shell-footer') %>
