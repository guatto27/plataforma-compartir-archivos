<%- include('../partials/shell-header') %>

<div class="page-head">
  <div class="head-row">
    <div>
      <h1>Entrevistas</h1>
      <p class="muted">Personas entrevistadas de todos tus clientes, con su link de Gemini y archivos asociados.</p>
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap">
      <a class="btn btn-ghost" href="/admin/archivos<%= (typeof projectFilter !== 'undefined' && projectFilter) ? ('?proyecto=' + projectFilter.id) : '' %>">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-3px;margin-right:6px"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
        Ver archivos
      </a>
      <button class="btn btn-primary" type="button" data-dialog="dlg-add-interview">+ Agregar entrevista</button>
    </div>
  </div>
</div>

<% if (typeof projectFilter !== 'undefined' && projectFilter) { %>
  <div class="flash flash-success">Proyecto: <strong><%= projectFilter.company_name %> — <%= projectFilter.name %></strong> · <a href="/admin">ver todas las entrevistas</a></div>
<% } %>

<dialog id="dlg-add-interview" class="modal" data-strict>
  <h2>Nueva entrevista</h2>
  <% if (!clients.length) { %>
    <p class="muted">Primero crea una empresa y un usuario en <a href="/admin/usuarios">Usuarios</a>.</p>
    <div class="modal-actions">
      <button class="btn btn-ghost" type="button" data-close>Cerrar</button>
    </div>
  <% } else { %>
    <form method="post" action="/admin/interviews">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label>Usuario
        <select name="client_id" required>
          <option value="">— Selecciona un usuario —</option>
          <% clients.forEach((c) => { %>
            <option value="<%= c.id %>"><%= c.display_name || c.username %><% if (c.company_name) { %> · <%= c.company_name %><% } %></option>
          <% }) %>
        </select>
      </label>
      <label>Nombre
        <input type="text" name="nombre" required maxlength="160" placeholder="ej. Juan Pérez" />
      </label>
      <label>Cargo
        <input type="text" name="cargo" maxlength="160" placeholder="ej. Gerente de Operaciones" />
      </label>
      <label>Área
        <input type="text" name="area" maxlength="160" placeholder="ej. Operaciones" />
      </label>
      <div class="modal-actions">
        <button class="btn btn-primary" type="submit">Agregar</button>
        <button class="btn btn-ghost" type="button" data-close>Cancelar</button>
      </div>
    </form>
  <% } %>
</dialog>

<%- include('../partials/interviewtable') %>

<%- include('../partials/shell-footer') %>
