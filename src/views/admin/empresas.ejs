<%- include('../partials/shell-header') %>

<div class="page-head">
  <div class="head-row">
    <div>
      <h1>Empresas</h1>
      <p class="muted">Registra las empresas (clientes). Después, en <a href="/admin/usuarios">Usuarios</a>, creas los accesos ligados a cada empresa.</p>
    </div>
    <% if (canManage) { %>
      <button class="btn btn-primary" type="button" data-dialog="dlg-new-company">+ Nueva empresa</button>
    <% } %>
  </div>
</div>

<section class="card">
  <h2>Empresas registradas</h2>
  <% if (companies.length === 0) { %>
    <p class="empty">Aún no hay empresas. Usa “+ Nueva empresa” para registrar la primera.</p>
  <% } else { %>
    <div class="table-wrap">
      <table class="table">
        <thead>
          <tr><th>Empresa</th><th>Contacto</th><th>Usuarios</th><% if (canManage) { %><th class="ta-actions">Acciones</th><% } %></tr>
        </thead>
        <tbody>
          <% companies.forEach((c) => { %>
            <tr>
              <td class="fname">
                <div style="display:flex;align-items:center;gap:12px">
                  <% if (c.logo_path) { %>
                    <img src="/admin/empresas/<%= c.id %>/logo" alt="<%= c.name %>" class="empresa-logo" />
                  <% } else { %>
                    <span class="empresa-logo empresa-logo-ph"><%= (c.name || '?').charAt(0).toUpperCase() %></span>
                  <% } %>
                  <span><%= c.name %><% if (c.notes) { %><div class="meta"><%= c.notes %></div><% } %></span>
                </div>
              </td>
              <td><%= c.contact || '—' %></td>
              <td><%= c.user_count %></td>
              <% if (canManage) { %>
              <td class="ta-actions">
                <button class="iconbtn" type="button" data-dialog="dlg-edit-company-<%= c.id %>" title="Editar" aria-label="Editar">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z"/></svg>
                </button>
                <form method="post" action="/admin/empresas/<%= c.id %>/delete" class="inline" data-confirm="¿Eliminar la empresa “<%= c.name %>”? (Solo se permite si no tiene usuarios.)">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button class="iconbtn danger" type="submit" title="Eliminar" aria-label="Eliminar">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                  </button>
                </form>
              </td>
              <% } %>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<% if (canManage) { %>
<% companies.forEach((c) => { %>
  <dialog id="dlg-edit-company-<%= c.id %>" class="modal" data-strict>
    <h2>Editar empresa</h2>
    <form method="post" action="/admin/empresas/<%= c.id %>/edit" enctype="multipart/form-data">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label>Nombre de la empresa
        <input type="text" name="name" value="<%= c.name %>" required maxlength="160" />
      </label>
      <label>Contacto (opcional)
        <input type="text" name="contact" value="<%= c.contact || '' %>" maxlength="160" />
      </label>
      <label>Proyecto (opcional)
        <input type="text" name="project" value="<%= c.project || '' %>" maxlength="160" placeholder="ej. Validación de Franquicias" />
      </label>
      <label>Eslogan (opcional)
        <input type="text" name="eslogan" value="<%= c.eslogan || '' %>" maxlength="160" placeholder="ej. Calidad que se saborea" />
      </label>
      <label>Notas (opcional)
        <input type="text" name="notes" value="<%= c.notes || '' %>" maxlength="500" />
      </label>
      <label>Logo de la empresa <%= c.logo_path ? '(reemplazar)' : '(opcional)' %>
        <div style="display:flex;align-items:center;gap:12px;margin-top:6px">
          <% if (c.logo_path) { %><img src="/admin/empresas/<%= c.id %>/logo" alt="" class="empresa-logo" /><% } %>
          <input type="file" name="logo" accept="image/png,image/jpeg,image/webp,image/svg+xml,image/gif" />
        </div>
      </label>
      <div class="modal-actions">
        <button class="btn btn-primary" type="submit">Guardar cambios</button>
        <button class="btn btn-ghost" type="button" data-close>Cancelar</button>
      </div>
    </form>
  </dialog>
<% }) %>

<dialog id="dlg-new-company" class="modal" data-strict>
  <h2>Nueva empresa</h2>
  <form method="post" action="/admin/empresas" enctype="multipart/form-data">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <label>Nombre de la empresa
      <input type="text" name="name" required maxlength="160" placeholder="ej. ACME S.A. de C.V." />
    </label>
    <label>Contacto (opcional)
      <input type="text" name="contact" maxlength="160" placeholder="ej. Juan Pérez / correo / teléfono" />
    </label>
    <label>Proyecto (opcional)
      <input type="text" name="project" maxlength="160" placeholder="ej. Validación de Franquicias" />
    </label>
    <label>Eslogan (opcional)
      <input type="text" name="eslogan" maxlength="160" placeholder="ej. Calidad que se saborea" />
    </label>
    <label>Notas (opcional)
      <input type="text" name="notes" maxlength="500" />
    </label>
    <label>Logo de la empresa (opcional)
      <input type="file" name="logo" accept="image/png,image/jpeg,image/webp,image/svg+xml,image/gif" style="margin-top:6px" />
    </label>
    <div class="modal-actions">
      <button class="btn btn-primary" type="submit">Registrar empresa</button>
      <button class="btn btn-ghost" type="button" data-close>Cancelar</button>
    </div>
  </form>
</dialog>
<% } %>

<%- include('../partials/shell-footer') %>
