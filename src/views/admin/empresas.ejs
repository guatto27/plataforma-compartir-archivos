<%- include('../partials/shell-header') %>

<div class="page-head">
  <div class="head-row">
    <div>
      <h1>Empresas</h1>
      <p class="muted">Registra las empresas (clientes). Después, en <a href="/admin/usuarios">Usuarios</a>, creas los accesos ligados a cada empresa.</p>
    </div>
    <% if (canManage) { %>
      <button class="btn btn-primary" type="button" data-dialog="dlg-new-company">+ Nueva empresa</button>
    <% } %>
  </div>
</div>

<section class="card">
  <h2>Empresas registradas</h2>
  <% if (companies.length === 0) { %>
    <p class="empty">Aún no hay empresas. Usa “+ Nueva empresa” para registrar la primera.</p>
  <% } else { %>
    <div class="table-wrap">
      <table class="table">
        <thead>
          <tr><th>Empresa</th><th>Proyectos</th><th class="ta-center">Logo</th><th class="ta-center">Nombre</th><th>Contacto</th><th class="ta-center">Usuarios</th><th class="ta-center"># Proy.</th><% if (canManage) { %><th class="ta-actions">Acciones</th><% } %></tr>
        </thead>
        <tbody>
          <% companies.forEach((c) => { %>
            <tr>
              <td class="fname">
                <div style="display:flex;align-items:center;gap:12px">
                  <% if (c.logo_path) { %>
                    <img src="/admin/empresas/<%= c.id %>/logo" alt="<%= c.name %>" class="empresa-logo" />
                  <% } else { %>
                    <span class="empresa-logo empresa-logo-ph"><%= (c.name || '?').charAt(0).toUpperCase() %></span>
                  <% } %>
                  <span><%= c.name %></span>
                </div>
              </td>
              <td>
                <% var plist = projByCompany[c.id] || []; %>
                <% if (plist.length) { %>
                  <% plist.forEach(function (p) { var pc = p.status === 'Finalizado' ? 'st-fin' : (p.status === 'En pausa' ? 'st-pau' : 'st-vig'); %>
                    <div class="proj-pill"><span><%= p.name %></span><span class="st-chip <%= pc %>"><%= p.status %></span></div>
                  <% }) %>
                <% } else { %><span class="meta">—</span><% } %>
              </td>
              <% var chkOk = '<svg class="check-circle" viewBox="0 0 24 24" fill="none" stroke="#3fb950" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M8 12.4l2.6 2.6 5-5.6"/></svg>'; %>
              <td class="ta-center"><% if (c.logo_path) { %><%- chkOk %><% } else { %><span class="meta">—</span><% } %></td>
              <td class="ta-center"><% if (c.eslogan_path) { %><%- chkOk %><% } else { %><span class="meta">—</span><% } %></td>
              <td><%= c.contact || '—' %></td>
              <td class="ta-center"><%= c.user_count %></td>
              <td class="ta-center"><%= c.project_count %></td>
              <% if (canManage) { %>
              <td class="ta-actions">
                <button class="iconbtn" type="button" data-dialog="dlg-edit-company-<%= c.id %>" title="Editar" aria-label="Editar">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z"/></svg>
                </button>
                <form method="post" action="/admin/empresas/<%= c.id %>/delete" class="inline" data-confirm="¿Eliminar la empresa “<%= c.name %>”? (Solo se permite si no tiene usuarios.)">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button class="iconbtn danger" type="submit" title="Eliminar" aria-label="Eliminar">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                  </button>
                </form>
              </td>
              <% } %>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<% if (canManage) { %>
<% companies.forEach((c) => { %>
  <dialog id="dlg-edit-company-<%= c.id %>" class="modal" data-strict>
    <h2>Editar empresa</h2>
    <form method="post" action="/admin/empresas/<%= c.id %>/edit" enctype="multipart/form-data">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label>Nombre de la empresa
        <input type="text" name="name" value="<%= c.name %>" required maxlength="160" />
      </label>
      <label>Contacto (opcional)
        <input type="text" name="contact" value="<%= c.contact || '' %>" maxlength="160" />
      </label>
      <label>Notas (opcional)
        <input type="text" name="notes" value="<%= c.notes || '' %>" maxlength="500" />
      </label>
      <label>Logo de la empresa <%= c.logo_path ? '(reemplazar)' : '(opcional)' %>
        <div style="display:flex;align-items:center;gap:12px;margin-top:6px">
          <% if (c.logo_path) { %><img src="/admin/empresas/<%= c.id %>/logo" alt="" class="empresa-logo" /><% } %>
          <input type="file" name="logo" accept="image/png,image/jpeg,image/webp,image/svg+xml,image/gif" />
        </div>
      </label>
      <label>Nombre de la empresa — imagen <%= c.eslogan_path ? '(reemplazar)' : '(opcional)' %>
        <span class="meta" style="font-weight:400;display:block;margin:2px 0 0">Versión del nombre como imagen (se le quita el fondo). Si no se sube, se usa el nombre de texto de arriba.</span>
        <div style="display:flex;align-items:center;gap:12px;margin-top:6px">
          <% if (c.eslogan_path) { %><img src="/admin/empresas/<%= c.id %>/eslogan" alt="" class="empresa-logo" /><% } %>
          <input type="file" name="eslogan_img" accept="image/png,image/jpeg,image/webp,image/svg+xml,image/gif" />
        </div>
      </label>
      <div class="modal-actions">
        <button class="btn btn-primary" type="submit">Guardar cambios</button>
        <button class="btn btn-ghost" type="button" data-close>Cancelar</button>
      </div>
    </form>

    <div class="proj-manager">
      <h3>Proyectos de la empresa</h3>
      <p class="meta">Cada proyecto tiene sus propias minutas, entregables y entrevistas. El cliente responsable los verá en su selector.</p>
      <% (projByCompany[c.id] || []).forEach(function (p) { %>
        <div class="proj-row">
          <form method="post" action="/admin/proyectos/<%= p.id %>/edit" class="proj-edit">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <input type="text" name="name" value="<%= p.name %>" maxlength="160" aria-label="Nombre del proyecto" />
            <select name="status" aria-label="Estatus">
              <% ['Vigente','En pausa','Finalizado'].forEach(function (s) { %>
                <option value="<%= s %>" <%= p.status === s ? 'selected' : '' %>><%= s %></option>
              <% }) %>
            </select>
            <button class="btn btn-ghost btn-sm" type="submit">Guardar</button>
          </form>
          <form method="post" action="/admin/proyectos/<%= p.id %>/delete" class="inline" data-confirm="¿Eliminar el proyecto “<%= p.name %>”? (Solo si no tiene minutas/entrevistas.)">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button class="iconbtn danger" type="submit" title="Eliminar proyecto" aria-label="Eliminar proyecto">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
            </button>
          </form>
        </div>
      <% }) %>
      <form method="post" action="/admin/empresas/<%= c.id %>/proyectos" class="proj-row proj-add">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input type="text" name="name" placeholder="Nuevo proyecto…" maxlength="160" required />
        <select name="status" aria-label="Estatus">
          <option value="Vigente">Vigente</option>
          <option value="En pausa">En pausa</option>
          <option value="Finalizado">Finalizado</option>
        </select>
        <button class="btn btn-primary btn-sm" type="submit">Agregar</button>
      </form>
    </div>
  </dialog>
<% }) %>

<dialog id="dlg-new-company" class="modal" data-strict>
  <h2>Nueva empresa</h2>
  <form method="post" action="/admin/empresas" enctype="multipart/form-data">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <label>Nombre de la empresa
      <input type="text" name="name" required maxlength="160" placeholder="ej. ACME S.A. de C.V." />
    </label>
    <label>Contacto (opcional)
      <input type="text" name="contact" maxlength="160" placeholder="ej. Juan Pérez / correo / teléfono" />
    </label>
    <label>Notas (opcional)
      <input type="text" name="notes" maxlength="500" />
    </label>
    <label>Logo de la empresa (opcional)
      <input type="file" name="logo" accept="image/png,image/jpeg,image/webp,image/svg+xml,image/gif" style="margin-top:6px" />
    </label>
    <label>Nombre de la empresa — imagen (opcional)
      <span class="meta" style="font-weight:400;display:block;margin:2px 0 0">Versión del nombre como imagen (se le quita el fondo). Si no, se usa el nombre de texto.</span>
      <input type="file" name="eslogan_img" accept="image/png,image/jpeg,image/webp,image/svg+xml,image/gif" style="margin-top:6px" />
    </label>
    <p class="meta" style="margin-top:2px">Los proyectos se agregan después, al editar la empresa o desde la sección Proyectos.</p>
    <div class="modal-actions">
      <button class="btn btn-primary" type="submit">Registrar empresa</button>
      <button class="btn btn-ghost" type="button" data-close>Cancelar</button>
    </div>
  </form>
</dialog>
<% } %>

<%- include('../partials/shell-footer') %>
