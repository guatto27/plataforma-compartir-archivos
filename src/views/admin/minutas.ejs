<%- include('../partials/shell-header') %>

<div class="page-head">
  <div class="head-row">
    <div>
      <h1>Gestión de Minutas</h1>
      <p class="muted">Genera, firma y publica minutas de sesión para cada empresa.</p>
    </div>
    <a href="/admin/minutas/nueva" class="btn btn-primary">+ Nueva minuta</a>
  </div>
</div>

<% if (!minutas.length) { %>
  <div class="empty-state">Aún no hay minutas. Crea la primera con el botón de arriba.</div>
<% } else { %>
  <section class="card">
    <table class="table">
      <thead>
        <tr><th>Título</th><th>Empresa</th><th>Fecha</th><th>Formato</th><th>Estado</th><th class="ta-actions">Acciones</th></tr>
      </thead>
      <tbody>
        <% minutas.forEach(function(m) {
             var fmt = FORMATOS.find(f => f.id === m.formato) || FORMATOS[0]; %>
        <tr>
          <td><a href="/admin/minutas/<%= m.id %>"><strong><%= m.titulo %></strong></a></td>
          <td><%= m.company_name || '—' %></td>
          <td class="nowrap meta"><%= m.fecha %></td>
          <td class="meta"><%= fmt.label %></td>
          <td>
            <% if (m.firmada) { %><span class="st aprob">Firmada</span>
            <% } else if (m.publicada) { %><span class="st rev">Publicada</span>
            <% } else if (m.contenido) { %><span class="st pend">Borrador</span>
            <% } else { %><span class="meta">Sin contenido</span><% } %>
          </td>
          <td class="ta-actions">
            <a class="iconbtn" href="/admin/minutas/<%= m.id %>" title="Ver/Editar">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.12 2.12 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            </a>
            <form method="post" action="/admin/minutas/<%= m.id %>/eliminar" class="inline" data-confirm="¿Eliminar la minuta '<%= m.titulo %>'?">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <button class="iconbtn danger" type="submit" title="Eliminar">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
              </button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </section>
<% } %>

<%- include('../partials/shell-footer') %>
