<%- include('../partials/shell-header') %>
<% function roleLabel(r){ return r === 'colaborador' ? 'Colaborador' : (r === 'cliente_responsable' ? 'Cliente responsable' : 'Usuario'); } %>

<div class="page-head">
  <div class="head-row">
    <div>
      <h1>Usuarios</h1>
      <p class="muted">Accesos a la plataforma. Los <strong>usuarios</strong> son de una empresa cliente; los <strong>colaboradores</strong> son del equipo de <%= brand.name %>.<% if (!canManage) { %> Solo el administrador puede dar de alta.<% } %></p>
    </div>
    <% if (canManage) { %>
      <button class="btn btn-primary" type="button" data-dialog="dlg-new-user">+ Nuevo usuario</button>
    <% } %>
  </div>
</div>

<section class="stats">
  <div class="stat"><span class="stat-num"><%= summary.total %></span><span class="stat-lbl">Usuarios</span></div>
  <div class="stat"><span class="stat-num"><%= summary.collaborators %></span><span class="stat-lbl">Colaboradores</span></div>
  <div class="stat"><span class="stat-num"><%= summary.withInterview %></span><span class="stat-lbl">Con entrevista</span></div>
  <div class="stat <%= summary.pending ? 'warn' : '' %>"><span class="stat-num"><%= summary.pending %></span><span class="stat-lbl">Pendientes</span></div>
</section>

<section class="card">
  <h2>Usuarios registrados</h2>
  <% if (users.length === 0) { %>
    <p class="empty">Aún no hay usuarios.<% if (canManage) { %> Usa “+ Nuevo usuario” para crear el primero.<% } %></p>
  <% } else { %>
    <div class="table-wrap">
      <table class="table">
        <thead>
          <tr><th>Empresa</th><th>Usuario</th><th>Tipo</th><th>Correo</th><th>Acceso</th><th>Contraseña temporal</th><th class="ta-actions">Acciones</th></tr>
        </thead>
        <tbody>
          <% users.forEach((u) => { %>
            <% var isNew = newCredentials && newCredentials.username === u.username; %>
            <tr class="<%= isNew ? 'row-active' : '' %>">
              <td><%= u.role === 'colaborador' ? '—' : (u.company_name_real || u.company_name || '—') %></td>
              <td>
                <strong><%= u.display_name || u.username %></strong>
                <div class="meta"><%= u.username %></div>
              </td>
              <td><span class="tag"><%= roleLabel(u.role) %></span></td>
              <td class="meta"><% if (isNew) { %><span id="cred-user"><%= u.email || u.username %></span><% } else { %><%= u.email || '—' %><% } %></td>
              <td><span class="pill <%= u.active ? 'ok' : 'off' %>"><%= u.active ? 'Activo' : 'Inactivo' %></span></td>
              <td>
                <% if (isNew) { %>
                  <div class="cred-cell">
                    <code id="cred-pass"><%= newCredentials.password %></code>
                    <button class="btn btn-ghost btn-sm" type="button" data-copy="cred-user|cred-pass" title="Copiar usuario y contraseña">Copiar</button>
                  </div>
                  <span class="meta">Solo se muestra ahora.</span>
                <% } else { %>
                  <span class="meta">—</span>
                <% } %>
              </td>
              <td class="ta-actions">
                <% if (canManage) { %>
                  <button class="iconbtn" type="button" data-dialog="dlg-edit-user-<%= u.id %>" title="Editar" aria-label="Editar">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z"/></svg>
                  </button>
                  <form method="post" action="/admin/usuarios/<%= u.id %>/reset-password" class="inline" data-confirm="¿Restablecer la contraseña de “<%= u.display_name || u.username %>”? Se generará una nueva temporal y se le enviará por correo.">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <button class="iconbtn" type="submit" title="Restablecer contraseña" aria-label="Restablecer contraseña">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2v6h-6"/><path d="M3 12a9 9 0 0 1 15-6.7L21 8"/><path d="M3 22v-6h6"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16"/></svg>
                    </button>
                  </form>
                  <form method="post" action="/admin/usuarios/<%= u.id %>/toggle-active" class="inline" data-confirm="<%= u.active ? '¿Desactivar el acceso de “' + (u.display_name || u.username) + '”? No podrá iniciar sesión.' : '¿Reactivar el acceso de “' + (u.display_name || u.username) + '”?' %>">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <button class="iconbtn <%= u.active ? 'danger' : '' %>" type="submit" title="<%= u.active ? 'Desactivar acceso' : 'Activar acceso' %>" aria-label="<%= u.active ? 'Desactivar acceso' : 'Activar acceso' %>">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18.36 6.64a9 9 0 1 1-12.73 0"/><line x1="12" y1="2" x2="12" y2="12"/></svg>
                    </button>
                  </form>
                  <form method="post" action="/admin/usuarios/<%= u.id %>/delete" class="inline" data-confirm="¿Eliminar a “<%= u.display_name || u.username %>”? Se borrarán también sus entrevistas y archivos. No se puede deshacer.">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <button class="iconbtn danger" type="submit" title="Eliminar" aria-label="Eliminar">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                    </button>
                  </form>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<% if (canManage) { %>
  <% users.forEach((u) => { %>
    <dialog id="dlg-edit-user-<%= u.id %>" class="modal" data-strict>
      <h2>Editar usuario</h2>
      <form method="post" action="/admin/usuarios/<%= u.id %>/edit" autocomplete="off">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <label>Tipo de usuario
          <select name="role">
            <option value="client" <%= u.role === 'client' ? 'selected' : '' %>>Usuario (cliente de una empresa)</option>
            <option value="cliente_responsable" <%= u.role === 'cliente_responsable' ? 'selected' : '' %>>Cliente responsable (de una empresa)</option>
            <option value="colaborador" <%= u.role === 'colaborador' ? 'selected' : '' %>>Colaborador (equipo <%= brand.name %>)</option>
          </select>
        </label>
        <label>Empresa (solo si es Usuario cliente)
          <select name="company_id">
            <option value="">— Sin empresa (colaborador) —</option>
            <% companies.forEach((co) => { %>
              <option value="<%= co.id %>" <%= u.company_id === co.id ? 'selected' : '' %>><%= co.name %></option>
            <% }) %>
          </select>
        </label>
        <label>Correo electrónico (acceso para iniciar sesión)
          <input type="email" name="email" value="<%= u.email || u.username || '' %>" required maxlength="160" />
        </label>
        <label>Nombre de contacto (nombre real)
          <input type="text" name="display_name" value="<%= u.display_name || '' %>" maxlength="120" />
        </label>
        <div class="modal-actions">
          <button class="btn btn-primary" type="submit">Guardar cambios</button>
          <button class="btn btn-ghost" type="button" data-close>Cancelar</button>
        </div>
      </form>
    </dialog>
  <% }) %>

  <dialog id="dlg-new-user" class="modal" data-strict <%= (typeof openNew !== 'undefined' && openNew) ? 'data-autoopen' : '' %>>
    <h2>Nuevo usuario</h2>
    <form method="post" action="/admin/usuarios" autocomplete="off">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label>Tipo de usuario
        <select name="role">
          <option value="client">Usuario (cliente de una empresa)</option>
          <option value="cliente_responsable">Cliente responsable (de una empresa)</option>
          <option value="colaborador">Colaborador (equipo <%= brand.name %>)</option>
        </select>
      </label>
      <label>Empresa (para Usuario y Cliente responsable; déjala vacía solo para Colaborador)
        <select name="company_id">
          <option value="">— Sin empresa (colaborador) —</option>
          <% companies.forEach((co) => { %>
            <option value="<%= co.id %>"><%= co.name %></option>
          <% }) %>
        </select>
      </label>
      <label>Correo electrónico (será su acceso y se le enviarán sus credenciales)
        <input type="email" name="email" required maxlength="160" placeholder="ej. juan@empresa.com" />
      </label>
      <p class="meta">El correo es el identificador para iniciar sesión.</p>
      <label>Nombre de contacto (nombre real)
        <input type="text" name="display_name" maxlength="120" placeholder="ej. Juan Pérez" />
      </label>
      <label>Contraseña temporal (déjala vacía para generar una)
        <input type="text" name="password" maxlength="200" placeholder="(opcional, mín. 10 caracteres)" />
      </label>
      <div class="modal-actions">
        <button class="btn btn-primary" type="submit">Crear usuario</button>
        <button class="btn btn-ghost" type="button" data-close>Cancelar</button>
      </div>
    </form>
  </dialog>
<% } %>

<%- include('../partials/shell-footer') %>
