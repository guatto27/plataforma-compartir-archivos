<%- include('../partials/shell-header') %>

<%
  function minutaEstado(m) {
    if (m.publicada) return { t: 'Publicada', c: 'st-vig' };
    if (m.firmada_cliente) return { t: 'Firmada (cliente)', c: 'st-vig' };
    if (m.firmada) return { t: 'Firmada', c: 'st-pau' };
    return { t: 'Borrador', c: 'st-fin' };
  }
%>

<div class="page-head">
  <p class="muted" style="margin:0 0 2px"><%= brand.name %></p>
  <h1>Panel de administración</h1>
  <p class="muted">Gestiona empresas, proyectos, minutas y usuarios desde un solo lugar.</p>
</div>

<!-- Acciones rápidas -->
<section class="card">
  <h2>Acciones rápidas</h2>
  <div class="home-shortcuts">
    <a class="btn btn-primary" href="/admin/empresas">+ Nueva empresa</a>
    <a class="btn btn-primary" href="/admin/proyectos">+ Nuevo proyecto</a>
    <a class="btn btn-primary" href="/admin/minutas/nueva">+ Nueva minuta</a>
    <a class="btn btn-ghost" href="/admin/usuarios">+ Nuevo usuario</a>
    <a class="btn btn-ghost" href="/admin">+ Nueva entrevista</a>
  </div>
</section>

<!-- Métricas -->
<div class="home-grid">
  <a class="card home-stat home-link" href="/admin/empresas">
    <span class="home-stat-label">Empresas</span>
    <strong class="home-stat-value"><%= stats.empresas %></strong>
    <span class="muted">Ver empresas →</span>
  </a>
  <a class="card home-stat home-link" href="/admin/proyectos">
    <span class="home-stat-label">Proyectos</span>
    <strong class="home-stat-value"><%= stats.proyectos %></strong>
    <span class="muted">Ver proyectos →</span>
  </a>
  <a class="card home-stat home-link" href="/admin/minutas">
    <span class="home-stat-label">Minutas publicadas</span>
    <strong class="home-stat-value"><%= stats.minutas %></strong>
    <span class="muted">Gestión de minutas →</span>
  </a>
  <a class="card home-stat home-link" href="/admin/usuarios">
    <span class="home-stat-label">Usuarios cliente</span>
    <strong class="home-stat-value"><%= stats.usuarios %></strong>
    <span class="muted">Gestión de usuarios →</span>
  </a>
  <a class="card home-stat home-link" href="/admin">
    <span class="home-stat-label">Entrevistas</span>
    <strong class="home-stat-value"><%= stats.entrevistas %></strong>
    <span class="muted">Ir al levantamiento →</span>
  </a>
  <a class="card home-stat home-link" href="/admin/archivos">
    <span class="home-stat-label">Archivos</span>
    <strong class="home-stat-value"><%= stats.archivos %></strong>
    <span class="muted">Ver archivos →</span>
  </a>
</div>

<div class="admin-cols">
  <!-- Estado de proyectos -->
  <section class="card">
    <h2>Estado de proyectos</h2>
    <div class="status-rows">
      <div class="status-row"><span class="st-chip st-vig">Vigente</span><strong><%= byStatus['Vigente'] %></strong></div>
      <div class="status-row"><span class="st-chip st-pau">En pausa</span><strong><%= byStatus['En pausa'] %></strong></div>
      <div class="status-row"><span class="st-chip st-fin">Finalizado</span><strong><%= byStatus['Finalizado'] %></strong></div>
    </div>
    <a class="btn btn-ghost btn-sm" href="/admin/proyectos" style="margin-top:14px">Ver todos los proyectos</a>
  </section>

  <!-- Minutas recientes -->
  <section class="card">
    <div class="head-row" style="margin-bottom:6px">
      <h2 style="margin:0">Minutas recientes</h2>
      <a class="meta" href="/admin/minutas">Ver todas →</a>
    </div>
    <% if (!recentMinutas.length) { %>
      <p class="empty">Aún no hay minutas.</p>
    <% } else { %>
      <ul class="mini-list">
        <% recentMinutas.forEach(function (m) { var e = minutaEstado(m); %>
          <li>
            <a href="/admin/minutas/<%= m.id %>" class="mini-title"><%= m.titulo %></a>
            <span class="mini-sub"><%= m.company_name || '—' %> · <%= m.fecha %></span>
            <span class="st-chip <%= e.c %>"><%= e.t %></span>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </section>
</div>

<!-- Empresas recientes -->
<section class="card">
  <div class="head-row" style="margin-bottom:6px">
    <h2 style="margin:0">Empresas recientes</h2>
    <a class="meta" href="/admin/empresas">Ver todas →</a>
  </div>
  <% if (!recentCompanies.length) { %>
    <p class="empty">Aún no hay empresas registradas.</p>
  <% } else { %>
    <div class="table-wrap">
      <table class="table">
        <thead>
          <tr><th>Empresa</th><th class="ta-center">Proyectos</th><th class="ta-center">Usuarios</th><th class="nowrap">Registrada</th></tr>
        </thead>
        <tbody>
          <% recentCompanies.forEach(function (c) { %>
            <tr>
              <td class="fname"><strong><%= c.name %></strong></td>
              <td class="ta-center"><%= c.project_count %></td>
              <td class="ta-center"><%= c.user_count %></td>
              <td class="nowrap meta"><%= fmtDate(c.created_at) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<%- include('../partials/shell-footer') %>
