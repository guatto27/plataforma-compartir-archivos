<%- include('../partials/shell-header') %>

<div class="page-head">
  <div class="head-row">
    <div>
      <h1>Clientes</h1>
      <p class="muted">Crea accesos, edita la información de cada cliente y revisa el estado. Solo tú (administrador) ves esta página.</p>
    </div>
    <button class="btn btn-primary" type="button" data-dialog="dlg-new-client">+ Nuevo cliente</button>
  </div>

</div>

<section class="stats">
  <div class="stat"><span class="stat-num"><%= summary.total %></span><span class="stat-lbl">Clientes</span></div>
  <div class="stat"><span class="stat-num"><%= summary.withInterview %></span><span class="stat-lbl">Con entrevista</span></div>
  <div class="stat"><span class="stat-num"><%= summary.withUploads %></span><span class="stat-lbl">Con archivos</span></div>
  <div class="stat <%= summary.pending ? 'warn' : '' %>"><span class="stat-num"><%= summary.pending %></span><span class="stat-lbl">Pendientes</span></div>
</section>

<% if (newCredentials) { %>
  <div class="card credentials">
    <h2>Credenciales generadas</h2>
    <p class="muted">Cópialas y compártelas con tu cliente por un canal seguro. <strong>No se volverán a mostrar.</strong></p>
    <div class="cred-row">
      <span>Usuario:</span> <code id="cred-user"><%= newCredentials.username %></code>
    </div>
    <div class="cred-row">
      <span>Contraseña temporal:</span> <code id="cred-pass"><%= newCredentials.password %></code>
    </div>
    <button class="btn btn-ghost" type="button" data-copy="cred-user|cred-pass">Copiar credenciales</button>
    <p class="meta">El cliente deberá cambiar la contraseña en su primer acceso.</p>
  </div>
<% } %>

<section class="card">
  <h2>Clientes registrados</h2>
  <% if (clients.length === 0) { %>
    <p class="empty">Aún no hay clientes. Usa “+ Nuevo cliente” para crear el primero.</p>
  <% } else { %>
    <div class="table-wrap">
      <table class="table">
        <thead>
          <tr><th>Cliente</th><th>Entrevistas</th><th>Archivos</th><th>Compartidos</th><th>Acceso</th><th class="ta-actions">Acciones</th></tr>
        </thead>
        <tbody>
          <% clients.forEach((c) => { %>
            <tr>
              <td>
                <a href="/admin/clients/<%= c.id %>"><strong><%= c.display_name || c.username %></strong></a>
                <div class="meta"><%= c.username %><% if (c.company_name) { %> · <%= c.company_name %><% } %></div>
              </td>
              <td>
                <% if (c.links > 0) { %><span class="pill ok">✓ <%= c.links %></span><% } else { %><span class="pill pend">Pendiente</span><% } %>
              </td>
              <td>
                <% if (c.files_in > 0) { %><span class="pill ok">✓ <%= c.files_in %></span><% } else { %><span class="pill pend">Pendiente</span><% } %>
              </td>
              <td><%= c.files_out %></td>
              <td><span class="pill <%= c.active ? 'ok' : 'off' %>"><%= c.active ? 'Activo' : 'Inactivo' %></span></td>
              <td class="ta-actions">
                <a class="iconbtn" href="/admin/clients/<%= c.id %>" title="Ver ficha" aria-label="Ver ficha">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                </a>
                <button class="iconbtn" type="button" data-dialog="dlg-edit-<%= c.id %>" title="Editar" aria-label="Editar">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z"/></svg>
                </button>
                <form method="post" action="/admin/clients/<%= c.id %>/delete" class="inline" data-confirm="¿Eliminar al cliente “<%= c.display_name || c.username %>”? Se borrarán también sus entrevistas y archivos. Esta acción no se puede deshacer.">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button class="iconbtn danger" type="submit" title="Eliminar" aria-label="Eliminar">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                  </button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<% clients.forEach((c) => { %>
  <dialog id="dlg-edit-<%= c.id %>" class="modal" data-strict>
    <h2>Editar cliente</h2>
    <form method="post" action="/admin/clients/<%= c.id %>/edit" autocomplete="off">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label>Usuario (para iniciar sesión)
        <input type="text" name="username" value="<%= c.username %>" required pattern="[a-z0-9._\-]{3,40}" title="Solo minúsculas, números y los signos . _ - (sin espacios, mayúsculas ni acentos). 3 a 40 caracteres." maxlength="40" />
      </label>
      <label>Nombre de contacto
        <input type="text" name="display_name" value="<%= c.display_name || '' %>" maxlength="120" />
      </label>
      <label>Empresa
        <input type="text" name="company_name" value="<%= c.company_name || '' %>" maxlength="120" />
      </label>
      <div class="modal-actions">
        <button class="btn btn-primary" type="submit">Guardar cambios</button>
        <button class="btn btn-ghost" type="button" data-close>Cancelar</button>
      </div>
    </form>
  </dialog>
<% }) %>

<dialog id="dlg-new-client" class="modal" data-strict>
  <h2>Nuevo cliente</h2>
  <form method="post" action="/admin/clients" autocomplete="off">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <label>Usuario (para iniciar sesión)
      <input type="text" name="username" required pattern="[a-z0-9._\-]{3,40}" title="Solo minúsculas, números y los signos . _ - (sin espacios, mayúsculas ni acentos). 3 a 40 caracteres." placeholder="ej. melisa.aguirre" maxlength="40" />
    </label>
    <p class="meta">Solo minúsculas, números y <code>. _ -</code> (sin espacios ni mayúsculas). Es el identificador de acceso, no el nombre real.</p>
    <label>Nombre de contacto (nombre real)
      <input type="text" name="display_name" maxlength="120" placeholder="ej. Melisa Aguirre" />
    </label>
    <label>Empresa
      <input type="text" name="company_name" maxlength="120" placeholder="ej. ACME S.A." />
    </label>
    <label>Contraseña temporal (déjala vacía para generar una)
      <input type="text" name="password" maxlength="200" placeholder="(opcional, mín. 10 caracteres)" />
    </label>
    <div class="modal-actions">
      <button class="btn btn-primary" type="submit">Crear cliente</button>
      <button class="btn btn-ghost" type="button" data-close>Cancelar</button>
    </div>
  </form>
</dialog>

<%- include('../partials/shell-footer') %>
